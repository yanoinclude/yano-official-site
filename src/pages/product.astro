---
import TextLink from "@/components/ui/TextLink.astro";
import YanoSpeechBubble from "@/components/animation/YanoSpeechBubble.astro";
import { homeContent } from "@/content/pages/home";
import { siteConfig } from "@/content/pages/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
import productBottle from "@/assets/images/product/weekend-lemon-juice.png";
import lemonGrove from "@/assets/images/hero-user-lemon-grove.jpg";

const farm = homeContent.currentActivities.lemonFarm;
const product = homeContent.product;

const farmOffers = [
  {
    number: "01",
    title: "レモンの収穫体験",
    body: "畑に入り、木の状態や実のつき方を見ながら、自分の手でレモンを収穫します。",
  },
  {
    number: "02",
    title: "週末移住レモン果汁",
    body: "この畑で受け取ったレモンを搾り、食卓から島との関係が始まる一本として届けています。",
  },
  {
    number: "03",
    title: "レモンの販売",
    body: "旬を迎える12月頃から6月中旬頃まで、生果のレモンを販売します。",
  },
  {
    number: "04",
    title: "企業向けノベルティ",
    body: "贈り物や催しに合わせた、企業・団体向けのレモン果汁のご相談も受け付けています。",
  },
  {
    number: "05",
    title: "畑の見学",
    body: "レモン畑や週末の活動を見てみたい方へ。時期と作業状況に合わせてご案内します。",
  },
];
---

<BaseLayout
  title="週末移住レモン果汁と100本のレモン畑"
  description="古民家のお隣さんから100本のレモンの木の手入れを任されたことから生まれた、週末移住レモン果汁の物語。"
>
  <article class="lemon-product-page">
    <YanoSpeechBubble />
    <section class="lemon-product-hero">
      <figure>
        <img src={productBottle.src} alt={product.imageAlt} />
      </figure>
      <div>
        <p class="section-title__en">{product.eyebrow}</p>
        <h1>{product.heading}</h1>
        <p class="lemon-product-hero__lead">{product.lead}</p>
        <p>{product.body}</p>
        <TextLink href={product.href} variant="quiet">
          {product.cta}
        </TextLink>
      </div>
    </section>

    <section class="lemon-story" aria-labelledby="lemon-story-title">
      <header>
        <p class="section-title__en">STORY</p>
        <h2 id="lemon-story-title">古民家の隣にあった、レモン畑。</h2>
      </header>
      <div class="lemon-story__body">
        <p>
          この畑は、古民家のお隣さんが長く手入れしてきた場所です。
          古民家再生を始めた頃から、一番近くで活動を見守り、
          みかんを差し入れてくれた農家さんでした。
        </p>
        <p>
          けれど、足を痛めてから、斜面での作業が難しくなっていきました。
          「もうレモンの木は全部切る」。そう聞いて畑を見に行ったとき、
          木がなくなることへの悲しさと、「残さないと」という衝動がありました。
        </p>
        <p>
          農業は初めてでした。それでも、100本の木の手入れを任せてもらい、
          週末に通いながら草を刈り、枝を見て、少しずつ覚えていくことにしました。
          畑を維持するだけでなく、収穫した実の行き先にも責任を持っています。
          古民家とレモン畑は、別々に始まった事業ではなく、
          島で受け取った関係の続きにあります。
        </p>
      </div>
      <figure>
        <img src={lemonGrove.src} alt={farm.imageAlt} loading="eager" />
      </figure>
    </section>

    <section class="farm-offers" aria-labelledby="farm-offers-title">
      <header>
        <p class="section-title__en">AT THE FARM</p>
        <h2 id="farm-offers-title">この農園で、できること。</h2>
        <p>
          収穫から商品づくり、畑を訪れる時間まで。季節と作業状況に合わせて、
          中島のレモンに触れる機会をひらいています。
        </p>
      </header>
      <ol>
        {
          farmOffers.map((offer) => (
            <li>
              <span>{offer.number}</span>
              <h3>{offer.title}</h3>
              <p>{offer.body}</p>
            </li>
          ))
        }
      </ol>
      <div class="farm-offers__links">
        <TextLink href={product.href} variant="quiet">
          週末移住レモン果汁を見る
        </TextLink>
        <TextLink href={siteConfig.social.productInstagram} variant="quiet">
          体験・見学についてInstagramで相談する
        </TextLink>
      </div>
    </section>

    <TextLink href="/#lemon-farm-detail" variant="quiet">
      トップページへ戻る
    </TextLink>
  </article>
</BaseLayout>

<style>
  :global(body) { background: #36a9ee; }
  :global(body:has(.lemon-product-page) .site-header) { display: none; }
  .lemon-product-page {
    position: relative;
    overflow: clip;
    padding: clamp(10rem, 14vw, 12rem) max(5vw, calc((100vw - 1180px) / 2)) clamp(6rem, 10vw, 9rem);
    background: #36a9ee;
    color: #fff;
  }
  .section-title__en {
    margin: 0 0 1rem;
    color: #ffe000;
    font-size: .75rem;
    font-weight: 800;
    letter-spacing: .16em;
  }
  .lemon-product-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(20rem, .95fr);
    gap: clamp(3rem, 7vw, 6rem);
    align-items: center;
    min-height: calc(100svh - clamp(10rem, 14vw, 12rem));
    padding-bottom: clamp(6rem, 10vw, 9rem);
  }
  .lemon-product-hero figure {
    display: grid;
    place-items: center;
    margin: 0;
    padding: clamp(1.2rem, 3vw, 2.2rem);
    border: 2px solid #143d62;
    border-radius: 1.2rem;
    background: #fffaf0;
    box-shadow: .65rem .7rem 0 #ffe000;
  }
  .lemon-product-hero img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 37rem;
    object-fit: contain;
  }
  .lemon-product-hero h1,
  .lemon-story h2,
  .farm-offers h2 {
    margin: 0;
    color: #fff;
    font-weight: 700;
    letter-spacing: .01em;
    text-wrap: balance;
  }
  .lemon-product-hero h1 {
    max-width: 9em;
    font-size: clamp(2.7rem, 4.7vw, 4.6rem);
    line-height: 1.35;
  }
  .lemon-product-hero__lead {
    margin: 1.6rem 0 .65rem;
    color: #ffe000;
    font-size: clamp(1.05rem, 1.5vw, 1.3rem);
    font-weight: 800;
  }
  .lemon-product-hero > div > p:not(.section-title__en) {
    max-width: 36rem;
    line-height: 1.9;
  }
  .lemon-product-hero .text-link { margin-top: 1.5rem; }
  .lemon-story,
  .farm-offers {
    padding-block: clamp(6rem, 10vw, 9rem);
    border-top: 1px solid rgb(255 255 255 / 48%);
  }
  .lemon-story {
    display: grid;
    grid-template-columns: minmax(16rem, .72fr) minmax(20rem, 1.08fr);
    column-gap: clamp(3rem, 8vw, 7rem);
  }
  .lemon-story h2,
  .farm-offers h2 {
    max-width: 18em;
    font-size: clamp(1.8rem, 3vw, 2.75rem);
    line-height: 1.5;
  }
  .lemon-story__body { padding-top: .5rem; }
  .lemon-story__body p {
    margin: 0 0 1.5rem;
    font-size: .96rem;
    font-weight: 500;
    line-height: 1.95;
  }
  .lemon-story figure {
    grid-column: 1 / -1;
    margin: clamp(3rem, 6vw, 5rem) 0 0;
    padding: .75rem;
    background: #fffaf0;
    box-shadow: .65rem .7rem 0 #ffe000;
    transform: rotate(-.45deg);
  }
  .lemon-story figure img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }
  .farm-offers > header {
    display: grid;
    grid-template-columns: minmax(17rem, .8fr) minmax(20rem, 1.2fr);
    gap: clamp(2.5rem, 7vw, 6rem);
    align-items: end;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }
  .farm-offers > header .section-title__en,
  .farm-offers > header h2 { grid-column: 1; }
  .farm-offers > header > p:last-child {
    grid-column: 2;
    grid-row: 1 / 3;
    margin: 0;
    font-size: .96rem;
    line-height: 1.95;
  }
  .farm-offers ol {
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid rgb(255 255 255 / 48%);
  }
  .farm-offers li {
    display: grid;
    grid-template-columns: 4rem minmax(13rem, .7fr) minmax(20rem, 1.3fr);
    gap: 2rem;
    align-items: start;
    padding-block: 1.8rem;
    border-bottom: 1px solid rgb(255 255 255 / 48%);
  }
  .farm-offers li > span {
    color: #ffe000;
    font-size: .72rem;
    font-weight: 800;
    letter-spacing: .14em;
  }
  .farm-offers li h3,
  .farm-offers li p { margin: 0; }
  .farm-offers li h3 {
    color: #fff;
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
    line-height: 1.55;
  }
  .farm-offers li p {
    color: rgb(255 255 255 / 88%);
    font-size: .9rem;
    line-height: 1.9;
  }
  .farm-offers__links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 3rem;
    margin-top: 2.5rem;
  }
  .lemon-product-page > .text-link:last-child { margin-top: 1rem; }
  @media (max-width: 900px) {
    .lemon-product-hero,
    .lemon-story,
    .farm-offers > header { grid-template-columns: 1fr; }
    .lemon-product-hero { min-height: 0; }
    .lemon-product-hero figure { order: 2; }
    .farm-offers > header .section-title__en,
    .farm-offers > header h2,
    .farm-offers > header > p:last-child { grid-column: 1; grid-row: auto; }
    .lemon-story figure { grid-column: 1; }
    .farm-offers li { grid-template-columns: 3rem minmax(12rem, .8fr) minmax(0, 1.2fr); gap: 1.25rem; }
  }
  @media (max-width: 767px) {
    .lemon-product-page { padding: 11.5rem 20px 5.5rem; }
    .lemon-product-hero { gap: 2.25rem; padding-bottom: 5.5rem; }
    .lemon-product-hero h1 { max-width: 11em; font-size: clamp(2.2rem, 10vw, 2.8rem); line-height: 1.4; }
    .lemon-product-hero figure { padding: .65rem; box-shadow: .4rem .45rem 0 #ffe000; }
    .lemon-story,
    .farm-offers { padding-block: 5.5rem; }
    .lemon-story h2,
    .farm-offers h2 { font-size: 1.75rem; }
    .lemon-story figure { padding: .45rem; box-shadow: .4rem .45rem 0 #ffe000; }
    .farm-offers > header { gap: 1.5rem; }
    .farm-offers li { grid-template-columns: 2.5rem minmax(0, 1fr); }
    .farm-offers li p { grid-column: 2; }
    .farm-offers__links { display: grid; gap: 1.25rem; }
  }
</style>

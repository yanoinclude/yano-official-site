  .empathy-section .section-kicker {
    display: inline-flex;
    margin-bottom: 0.85rem;
    padding: 0.3rem 0.55rem;
    border: 2px solid #111;
    border-radius: 0.35rem;
    color: #111;
    font-family: "Arial Rounded MT Bold", "Noto Sans JP", sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .empathy-section h2 {
    max-width: none;
    color: #ff3f9f;
    font-size: 2.3rem;
    font-weight: 800;
    line-height: 1.35;
  }

  .empathy-section h2 span {
    display: block;
    white-space: nowrap;
  }

  .empathy-section__lead {
    margin: clamp(1rem, 2vw, 1.5rem) 0 0;
    color: #111;
    font-size: 1.2rem;
    font-weight: 800;
    line-height: 1.65;
  }

  .empathy-section__copy {
    grid-area: copy;
    margin: 0;
  }

  .empathy-section__copy p {
    margin: 0;
    color: #111;
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.95;
  }

  .empathy-section__copy p + p {
    margin-top: 1rem;
  }

  .empathy-section__photo {
    grid-area: photo;
    margin: 0;
    overflow: hidden;
    width: 100%;
  }

  .empathy-section__photo img {
    display: block;
    width: 100%;
    height: 100%;
    max-height: none;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: 30% center;
  }

  .concept-section {
    padding-block: clamp(4.5rem, 8vw, 7rem);
    background: #36a9ee;
    color: #2e4568;
  }

  .concept-section .section-kicker,
  .concept-section h2,
  .concept-section__copy {
    color: #2e4568;
  }

  .profile-section {
    padding-block: clamp(4.5rem, 8vw, 7rem);
    background: #36a9ee;
    color: #fff;
  }

  .profile-section__heading {
    margin-bottom: clamp(2.5rem, 5vw, 4.5rem);
    text-align: center;
  }

  .profile-section__heading .section-kicker {
    margin: 0;
    color: #fff;
    font-size: 5rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    line-height: 1;
  }

  .profile-section__heading > p:last-child {
    margin: 0.85rem 0 0;
    color: #ffe500;
    font-size: 1.2rem;
    font-weight: 700;
  }

  .profile-section__layout {
    display: grid;
    grid-template-columns: minmax(0, 1.04fr) minmax(0, 0.96fr);
    gap: clamp(2.5rem, 6vw, 6rem);
    align-items: center;
  }

  .profile-section__photo {
    min-width: 0;
    margin: 0;
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }

  .profile-section__photo img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 47% center;
  }

  .profile-section__details {
    display: grid;
    gap: clamp(1.5rem, 3vw, 2.4rem);
    min-width: 0;
  }

  .profile-section__primary {
    padding: clamp(1.6rem, 3vw, 2.5rem);
    border-radius: 1.4rem;
    background: #fff;
    color: #2e4568;
  }

  .profile-section__primary h2 {
    margin: 0;
    color: #2e4568;
    font-size: 1.8rem;
    line-height: 1.45;
  }

  .profile-section__primary h2 span {
    font-size: 0.72em;
    white-space: nowrap;
  }

  .profile-section__name-en {
    margin: 0.2rem 0 1rem;
    color: #36a9ee;
    font-weight: 800;
  }

  .profile-section__primary > p:last-child,
  .profile-section__secondary p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.9;
  }

  .profile-section__secondary {
    padding: 0 0 clamp(1.5rem, 3vw, 2rem);
    border-bottom: 3px dotted rgb(255 255 255 / 70%);
    color: #fff;
  }

  .profile-section__secondary h3 {
    margin: 0 0 0.45rem;
    color: #fff;
    font-size: 1.65rem;
  }

  .profile-section__more {
    display: inline-grid;
    min-width: 8.5rem;
    min-height: 3.2rem;
    place-items: center;
    justify-self: end;
    border: 2px solid #111;
    border-radius: 999px;
    background: #fff;
    color: #111;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-decoration: none;
    box-shadow: 0 0.3rem 0 #111;
  }

  .profile-section__more:hover,
  .profile-section__more:focus-visible {
    background: #ffe500;
    transform: translateY(-0.1rem);
  }

  .place-section {
    position: relative;
    display: block;
    width: 100vw;
    max-width: none;
    margin-inline: calc(50% - 50vw);
    padding: clamp(2.5rem, 4.5vw, 4rem) 0 clamp(6rem, 11vw, 10rem);
    overflow: hidden;
    background: #36a9ee;
  }

  .place-section::before {
    display: none;
  }

  .place-section__intro {
    display: grid;
    position: relative;
    z-index: 1;
    grid-template-columns: 1fr;
    padding: clamp(2.5rem, 4vw, 3.5rem) clamp(1.5rem, 4vw, 4rem) 0;
  }

  .place-section__copy {
    max-width: none;
    margin: 0;
    text-align: left;
  }

  .place-section__copy .section-kicker {
    margin: 0;
    color: #fff;
    font-family: var(--font-island-body);
    font-size: clamp(3.4rem, 6vw, 5.5rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: 0.025em;
  }

  .place-section__copy h2 {
    margin: 1rem 0 0;
    color: #ffe500;
    font-family: var(--font-island-body);
    font-size: clamp(1rem, 1.6vw, 1.35rem);

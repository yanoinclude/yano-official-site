---
import JournalCard from "@/components/sections/JournalCard.astro";
import TextLink from "@/components/ui/TextLink.astro";
import { homeContent } from "@/content/pages/home";
import { siteConfig } from "@/content/pages/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="愛媛県松山市・中島の風景とレモン"
  description={siteConfig.description}
>
  <section class="hero" aria-label="週末移住レモンのファーストビュー">
    <div class="hero__rail" aria-hidden="true">
      <span>{siteConfig.name}</span>
    </div>
    <div class="hero__track">
      <figure class="hero__image">
        <img src={homeContent.hero.image} alt={homeContent.hero.imageAlt} />
      </figure>
    </div>
    <p class="eyebrow hero__label">Nakajima, Matsuyama</p>
    <div class="hero__copy-block">
      <h1>
        <span>島の続きを、手入れする。</span>
      </h1>
    </div>
    <span class="hero__scroll" aria-hidden="true">scroll</span>
  </section>

  <section class="philosophy-section reveal-section" id="philosophy">
    <div class="philosophy-paper">
      <p class="philosophy-paper__label">99 + 1 Project｜原体験</p>
      <div class="philosophy-paper__body" aria-label="島の風景を手入れする理由">
        <p>愛媛・中島という島で。</p>
        <p>築100年の古民家を2円で譲り受け、100本のレモンの木を任されました。</p>
        <p>なぜ、いま、古民家や畑に手を入れるのか。</p>
        <p>
          島の家や畑は、何十年、何百年と、誰かの手によって守られてきたものです。
        </p>
        <p>
          それが少しずつ失われていくことを、見過ごすことができませんでした。
        </p>
        <p>
          すべてを守ることはできなくても、気に留めたものに、自分たちのできる範囲で手を入れていく。
        </p>
        <p>
          古民家を直すことも、レモンの木を手入れすることも、私たちにとって、別々の仕事ではありません。
        </p>
        <p>
          この島に帰ってこられる風景を、次の世代へ手渡していくための営みです。
        </p>
      </div>
      <h2 class="philosophy-paper__heading">
        <span>この島に、</span>
        <span>帰ってこられる風景を。</span>
      </h2>
    </div>
  </section>

  <section class="scenery-section reveal-section" id="scenery">
    <div class="scenery-heading" aria-label="SCENERY in Nakajima">
      <p>SCENERY</p>
      <span>in Nakajima</span>
    </div>
    <figure class="scenery-panorama">
      <img
        src={homeContent.scenery.images[0].src}
        alt={homeContent.scenery.images[0].alt}
      />
      <figcaption>
        <span>SCENERY</span>
        <span>NAKAJIMA</span>
      </figcaption>
    </figure>
    <a class="scenery-image-link" href="/landscape">島の風景をのぞく</a>
  </section>

  <section class="about-section reveal-section" id="about">
    <div class="section-grid">
      <div class="section-copy">
        <p class="eyebrow">{homeContent.about.eyebrow}</p>
        <h2>{homeContent.about.heading}</h2>
        {homeContent.about.body.map((paragraph) => <p>{paragraph}</p>)}
        <TextLink href="/about" variant="quiet">私たちについて</TextLink>
      </div>
      <figure class="section-photo section-photo--landscape">
        <img src={homeContent.about.image} alt={homeContent.about.imageAlt} />
      </figure>
    </div>
  </section>

  <p class="concept-section__outer-label">{homeContent.concept.eyebrow}</p>

  <section
    class="concept-section reveal-section"
    id="concept"
    style={`--concept-image: url('${homeContent.concept.image}')`}
  >
    <div class="concept-section__heading">
      <h2>{homeContent.concept.headline}</h2>
    </div>
    <p class="concept-section__framed">
      {homeContent.concept.framedMessage.map((line) => <span>{line}</span>)}
    </p>
    <div class="concept-section__body" aria-label={homeContent.concept.body}>
      {homeContent.concept.bodyColumns.map((column) => <p>{column}</p>)}
    </div>
    <div class="concept-list">
      {
        homeContent.concept.ideas.map((idea) => (
          <article>
            <p class="concept-list__label">{idea.label}</p>
            <h3>{idea.title}</h3>
            <p>{idea.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="activities-section reveal-section" id="activities">
    <div class="section-title section-title--row">
      <div>
        <p class="section-title__en">{homeContent.activities.eyebrow}</p>
        <h2>{homeContent.activities.heading}</h2>
      </div>
      <p>{homeContent.activities.lead}</p>
    </div>
    <div class="activity-list activity-list--compact">
      {
        homeContent.activities.items.map((item, index) => (
          <article class="activity-row">
            <figure>
              <img src={item.image} alt={item.alt} />
            </figure>
            <div>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
              <TextLink href={item.href} variant="quiet">
                詳しく見る
              </TextLink>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="product-section reveal-section" id="product">
    <figure class="product-section__image">
      <img src={homeContent.product.image} alt={homeContent.product.imageAlt} />
    </figure>
    <div class="product-section__text">
      <p class="section-title__en">{homeContent.product.eyebrow}</p>
      <h2>{homeContent.product.heading}</h2>
      <p class="product-section__lead">{homeContent.product.lead}</p>
      <p>{homeContent.product.body}</p>
      <TextLink href="/product" variant="quiet">購入ページを見る</TextLink>
    </div>
  </section>

  <section class="experience-section reveal-section" id="experience">
    <div class="section-grid section-grid--reverse">
      <figure class="section-photo section-photo--landscape">
        <img
          src={homeContent.experience.image}
          alt={homeContent.experience.imageAlt}
        />
      </figure>
      <div class="section-copy">
        <p class="eyebrow">{homeContent.experience.eyebrow}</p>
        <h2>{homeContent.experience.heading}</h2>
        <p>{homeContent.experience.body}</p>
      </div>
    </div>
    <ul class="experience-list" aria-label="島との関わり方">
      {homeContent.experience.items.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="journal-section reveal-section" id="journal">
    <div class="section-title section-title--row">
      <div>
        <p class="section-title__en">{homeContent.journal.eyebrow}</p>
        <h2>{homeContent.journal.heading}</h2>
      </div>
      <p>{homeContent.journal.body}</p>
    </div>
    <div class="journal-showcase">
      <article class="journal-feature">
        <figure>
          <img
            src={homeContent.journal.items[0].image}
            alt={homeContent.journal.items[0].imageAlt}
          />
        </figure>
        <JournalCard
          title={homeContent.journal.items[0].title}
          date={homeContent.journal.items[0].date}
          excerpt={homeContent.journal.items[0].excerpt}
          href={homeContent.journal.items[0].href}
        />
      </article>
      <div class="journal-list">
        {
          homeContent.journal.items
            .slice(1)
            .map((article) => (
              <JournalCard
                title={article.title}
                date={article.date}
                excerpt={article.excerpt}
                href={article.href}
              />
            ))
        }
      </div>
    </div>
  </section>

  <section class="news-section reveal-section" id="news">
    <div class="news-section__inner">
      <div>
        <p class="section-title__en">{homeContent.news.eyebrow}</p>
        <h2>{homeContent.news.heading}</h2>
      </div>
      <div class="news-list">
        {
          homeContent.news.items.map((item) => (
            <a href={item.href}>
              <time datetime={item.date.replaceAll(".", "-")}>{item.date}</time>
              <span>{item.title}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section
    class="closing-section reveal-section"
    aria-label="クロージングメッセージ"
  >
    <figure>
      <img src={homeContent.closing.image} alt={homeContent.closing.imageAlt} />
    </figure>
    <div>
      <p class="closing-section__vertical">
        帰る人を迎え、<br />
        旅立つ人を見送る。
      </p>
      <div class="closing-section__body">
        <p>この島に残り続ける風景を、</p>
        <p>次の世代へ。</p>
      </div>
    </div>
  </section>

  <script>
    const revealTargets = document.querySelectorAll(".reveal-section");

    if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.setAttribute("data-in-view", "true");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 },
      );

      revealTargets.forEach((target) => observer.observe(target));
    } else {
      revealTargets.forEach((target) =>
        target.setAttribute("data-in-view", "true"),
      );
    }
  </script>
</BaseLayout>

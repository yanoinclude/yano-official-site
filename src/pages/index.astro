  /* Personal-branding refresh: resilient typography and content-led sizing. */
  :global(html:has(.weekend-hero)) { font-size: 100%; overflow-x: clip; }
  :global(body:has(.weekend-hero)) { overflow-x: clip; }
  :global(body:has(.weekend-hero) p) { line-break: strict; text-wrap: pretty; }
  :global(body:has(.weekend-hero) h1),
  :global(body:has(.weekend-hero) h2),
  :global(body:has(.weekend-hero) h3) { line-break: strict; text-wrap: balance; }

  .weekend-hero {
    box-sizing: border-box;
    width: 100%;
    margin-inline: 0;
  }
  .site-name { font-size: clamp(1.3rem, 2.1vw, 1.8rem); }
  .hero-introduction {
    width: min(36rem, calc(100% - 3rem));
    max-width: 36rem;
    font-size: clamp(0.95rem, 1.25vw, 1.08rem);
    line-height: 1.85;
  }

  .weekend-intro { overflow: clip; }
  .weekend-intro__grid { align-items: stretch; }
  .weekend-intro__story { display: grid; grid-template-rows: auto auto 1fr; }
  .weekend-intro__story figure { width: 100%; aspect-ratio: 16 / 10; }
  .weekend-intro__story img { width: 100%; height: 100%; object-fit: cover; }
  .weekend-intro__story h3 { font-size: clamp(1.25rem, 2vw, 1.65rem); }
  .weekend-intro__story > p { max-width: 42rem; font-size: clamp(0.95rem, 1.15vw, 1rem); line-height: 1.85; }

  .activities-section { padding-block: clamp(5rem, 9vw, 8rem); overflow: clip; }
  .ranking-section__heading { max-width: 48rem; margin-bottom: clamp(2.5rem, 5vw, 4rem); }
  .ranking-section__heading h2 { margin: 0; font-size: clamp(2rem, 4vw, 3.25rem); line-height: 1.35; }
  .ranking-section__lead { max-width: 42rem; margin: 1.25rem 0 0; font-size: 1rem; line-height: 1.85; }
  .activities-list { width: 100%; }
  .activities-section__grid {
    position: static;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1.25rem, 2.5vw, 2rem);
    width: 100%;
    min-height: 0;
  }
  .ranking-slide,
  .ranking-slide.is-active,
  .ranking-slide.is-left,
  .ranking-slide.is-right {
    position: relative;
    inset: auto;
    display: flex;
    width: auto;
    max-width: none;
    min-height: 0;
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }
  .ranking-card {
    display: grid;
    grid-template-rows: auto 1fr;
    width: 100%;
    overflow: hidden;
    border: 2px solid #111;
    border-radius: 1rem;
    background: #fff;
    box-shadow: 0.45rem 0.45rem 0 #f8dc42;
  }
  .ranking-card__media { width: 100%; aspect-ratio: 4 / 3; border-radius: 0; }
  .ranking-card__media img { width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .ranking-card__content { display: flex; flex-direction: column; min-height: 0; padding: clamp(1.25rem, 2.2vw, 1.75rem); background: #fff; }
  .ranking-card__category { margin: 0 0 0.6rem; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; }
  .ranking-card__content h3 { margin: 0; font-size: clamp(1.25rem, 1.9vw, 1.55rem); line-height: 1.5; }

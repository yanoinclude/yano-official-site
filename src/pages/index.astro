  .place-section__map iframe {
    display: block;
    width: 100%;
    height: clamp(30rem, 42vw, 35rem);
    border: 0;
    background: #fffdf6;
  }

  .place-section__map a {
    justify-self: end;
    margin-top: 0.9rem;
    color: #171717;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;

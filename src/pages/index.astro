  .empathy-section__layer--black {
    background: #111;
    transform: translate(-1rem, 1.35rem) rotate(-2.2deg);
  }

  .empathy-section__layer--yellow {
    background: #ffe500;
    transform: translate(0.85rem, 0.7rem) rotate(1.8deg);
  }

  .empathy-section__panel {
    position: relative;
    z-index: 1;
    padding: clamp(2.5rem, 5vw, 4.5rem);
    background: #fff;
    color: #111;
    transform: rotate(-1deg);

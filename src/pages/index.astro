      transform: translate(0, 0) rotate(-2deg);
    }

    30% {
      transform: translate(0.35rem, -0.45rem) rotate(-0.5deg);
    }

    58% {
      transform: translate(0.75rem, 0.12rem) rotate(1deg);
    }

    80% {
      transform: translate(0.25rem, 0.35rem) rotate(-1deg);
    }
  }

  @keyframes yano-step {
    0%,
    100% {
      transform: translateY(0) rotate(-1.5deg);
    }

    50% {
      transform: translateY(-0.26rem) rotate(2deg);
    }
  }

  .empathy-section,
  .place-section,
  .faq-section,
  .works-section {
    padding-block: clamp(5rem, 10vw, 9rem);
  }

  .empathy-section__grid,
  .concept-section__inner,
  .place-section {
    display: grid;
    grid-template-columns: minmax(18rem, 0.85fr) minmax(0, 1.15fr);
    gap: clamp(2rem, 6vw, 6rem);
    align-items: start;
  }

  .empathy-section__body,
  .concept-section__copy,
  .place-section__copy {
    color: #2e4568;
    font-size: 1.08rem;
    font-weight: 400;
    line-height: 2.15;

  .empathy-section__panel::before,
  .empathy-section__panel::after {
    display: none;
  }

  .empathy-section__content {
    display: grid;
    grid-template-areas:
      "heading photo"
      "copy photo";
    grid-template-columns: minmax(18rem, 0.9fr) minmax(0, 1.1fr);
    gap: 2rem clamp(3rem, 5vw, 4.5rem);
    align-items: start;
    margin-inline: auto;
    transform: rotate(1deg);

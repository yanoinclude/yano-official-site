  .place-story {
    display: grid;
    align-items: center;
  }

  .place-story figure {
    margin: 0;
  }

  .place-story img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .place-story--ferry {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(3rem, 5vw, 5rem);
  }

  .place-story--ferry figure {
    aspect-ratio: 4 / 3;
  }

  .place-story--ferry > div {
    align-self: start;
    max-width: 32rem;
    padding-top: clamp(2rem, 3vw, 2.65rem);
  }

  .place-story h3 {
    margin: 0;
    color: #171717;
    font-family: var(--font-island-body);
    font-size: clamp(1.75rem, 2.4vw, 2.15rem);
    font-weight: 600;
    line-height: 1.55;
  }

  .place-story--ferry h3 {
    white-space: nowrap;
  }

  .place-story h3 + p {
    margin: 1.5rem 0 0;
    color: #202020;
    font-size: 1rem;
    line-height: 2.15;
  }

  .activities-section {
    padding-block: clamp(4rem, 7vw, 6rem);
    background: #36a9ee;
    color: #fff;
    overflow: hidden;
  }

  .ranking-section__heading {
    text-align: center;
  }

  .ranking-section__heading .section-kicker {
    margin: 0;
    color: #fff;
    font-size: 5rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    line-height: 1;
  }

  .ranking-section__subtitle {
    margin: 0.85rem 0 0;
    color: #ffe500;
    font-size: 1.2rem;
    font-weight: 700;
  }

  .ranking-section__subtitle span {
    display: inline-block;
    white-space: nowrap;
  }

  .activities-carousel {
    display: grid;
    grid-template-columns:
      minmax(0, 1fr) 3rem minmax(0, 1fr) 3rem
      minmax(0, 1fr);
    gap: clamp(0.75rem, 1.6vw, 1.5rem);
    align-items: center;
    width: min(100%, 76rem);
    margin: clamp(2.5rem, 5vw, 4.5rem) auto 0;
    padding: 1.1rem 0.35rem 0.65rem;
    overflow: visible;
  }

  .activities-section__grid {
    display: contents;
  }

  .ranking-slide {
    position: relative;
    display: none;
    min-width: 0;
    height: 100%;
    padding-top: 0.7rem;
    overflow: visible;
    transition:
      opacity 0.28s ease,
      transform 0.28s ease;
  }

  .ranking-slide.is-left,
  .ranking-slide.is-active,
  .ranking-slide.is-right {
    display: block;
  }

  .ranking-slide.is-left {
    grid-column: 1;
    grid-row: 1;
  }

  .ranking-slide.is-active {
    grid-column: 3;
    grid-row: 1;
    z-index: 2;
    transform: translateY(-0.65rem);
  }

  .ranking-slide.is-right {
    grid-column: 5;
    grid-row: 1;
  }

  .ranking-card {
    display: flex;
    min-width: 0;
    min-height: clamp(32rem, 45vw, 36rem);
    height: 100%;
    box-sizing: border-box;
    flex-direction: column;
    padding: clamp(2rem, 3vw, 2.5rem) clamp(1.2rem, 2vw, 1.7rem)
      clamp(2.5rem, 4vw, 3.4rem);
    overflow: hidden;
    border-radius: 999px;
    background: #b3ddf9;
    color: #2e4568;
    opacity: 0.72;
  }

  .ranking-slide.is-active .ranking-card {
    background: #fff;
    opacity: 1;
  }

  .ranking-card figure {
    width: 100%;
    min-height: 0;
    margin: 0;
    overflow: hidden;
    border-radius: 0.2rem;
    aspect-ratio: 4 / 3;
  }

  .ranking-card img {
    display: block;
    width: 100%;
    max-width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ranking-card__content {
    min-width: 0;
    padding-top: 1.1rem;
  }

  .ranking-card h3 {
    margin: 0;
    color: #2e4568;
    font-size: 1.18rem;
    font-weight: 700;
    line-height: 1.5;
    line-break: strict;
  }

  .ranking-card p {
    margin: 0.7rem 0 0;
    color: #2e4568;
    font-size: 0.92rem;
    font-weight: 500;
    line-height: 1.72;
    line-break: strict;
  }

  .ranking-card .ranking-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.2rem 0.55rem;
    margin-top: 0.45rem;
    color: #2e4568;
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1.45;
  }

  .ranking-card__tags span {
    white-space: nowrap;
  }

  .ranking-card__badge {
    position: absolute;
    z-index: 5;
    top: 0;
    left: 0.55rem;
    display: grid;
    width: 3.1rem;
    aspect-ratio: 1;
    place-items: center;
    clip-path: polygon(
      50% 0%,
      61% 10%,
      76% 4%,
      83% 19%,
      99% 23%,
      92% 39%,
      100% 53%,
      86% 62%,
      88% 79%,
      71% 79%,
      62% 96%,
      49% 86%,
      34% 97%,
      27% 81%,
      10% 84%,
      12% 66%,
      0% 54%,
      10% 41%,
      2% 26%,
      19% 21%,
      25% 5%,
      40% 11%
    );
    background: #a7d875;
    color: #2e4568;
    font-size: 1.15rem;
    font-weight: 800;
  }

  .ranking-slide.is-active .ranking-card__badge {
    background: #ff3f9f;
    color: #fff;
  }

  .activities-carousel__button {
    position: relative;
    z-index: 3;
    display: grid;
    width: 2.6rem;
    height: 2.6rem;
    place-items: center;
    border: 2px solid #111;
    border-radius: 50%;
    background: #fff;
    color: #111;
    cursor: pointer;
    font-size: 1.45rem;
    line-height: 1;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease;
  }

  .activities-carousel__button:hover,
  .activities-carousel__button:focus-visible {
    background: #ffe500;
    transform: scale(1.05);
  }

  .activities-carousel__button--prev {
    grid-column: 2;
    grid-row: 1;
  }

  .activities-carousel__button--next {
    grid-column: 4;
    grid-row: 1;
  }

  .activities-carousel__dots {
    display: flex;
    justify-content: center;
    gap: 0.55rem;
    margin-top: 1.35rem;
  }

  .activities-carousel__dots span {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: #111;
  }

  .activities-carousel__dots span.is-active {
    outline: 2px solid #ffe500;
    outline-offset: 2px;
  }

  .message-wordmark {
    display: flex;
    align-items: stretch;
    justify-content: center;
    gap: clamp(0.55rem, 1.5vw, 1.25rem);
    margin-top: clamp(4rem, 8vw, 7rem);
    padding-bottom: clamp(1rem, 3vw, 2rem);
  }

  .message-wordmark span {
    display: grid;
    width: clamp(3.5rem, 7vw, 5.8rem);
    height: clamp(13rem, 22vw, 18rem);
    place-items: center;
    background: rgb(255 255 255 / calc(0.12 + var(--wordmark-index) * 0.14));
    color: #36a9ee;
    font-size: 1.45rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    writing-mode: vertical-rl;
  }

  .message-wordmark span:last-child {
    background: #fff;
  }

  .pathways-section figure,
  .works-section figure {
    margin: 0;
    overflow: hidden;
    background: #e6e7e2;
  }

  .pathways-section img,
  .works-section img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .pathways-section img {
    object-fit: contain;
  }

  .faq-section__list {
    display: grid;
    margin-top: clamp(2rem, 5vw, 4rem);
    border-top: 2px solid #2e4568;
  }

  .faq-section details {
    border-bottom: 1px solid #d8d2c5;
    background: transparent;
  }

  .faq-section summary {
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
    min-height: 4.8rem;
    cursor: pointer;
    color: #2e4568;
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.45;
    list-style: none;
  }

  .faq-section summary::-webkit-details-marker {
    display: none;
  }

  .faq-section summary::after {
    flex: 0 0 auto;
    content: "+";
    font-size: 1.5rem;
  }

  .faq-section details[open] summary::after {
    content: "−";
  }

  .faq-section p {
    max-width: 50rem;
    margin: 0;
    padding: 0 0 1.5rem;
    color: #2e4568;
    font-weight: 400;
    line-height: 2;
  }

  .pathways-section {
    padding-block: clamp(5rem, 9vw, 9rem);
    background: #36a9ee;
  }

  .pathways-section__inner {
    display: grid;
    grid-template-columns: minmax(15rem, 0.72fr) minmax(34rem, 1.28fr);
    gap: clamp(3rem, 7vw, 7rem);
    align-items: start;
  }

  .pathways-section__heading {
    display: grid;
    gap: 0;
    position: sticky;
    top: 7rem;
    padding-top: 0.4rem;
  }

  .pathways-section__heading h2 {
    margin-top: clamp(1.6rem, 4vw, 3.5rem);
    font-size: clamp(2rem, 3.2vw, 3.6rem);
    line-height: 1.35;
  }

  .pathways-section__heading > p:last-child {
    margin: clamp(1.5rem, 3vw, 2.5rem) 0 0;
    color: #2e4568;
    font-weight: 400;
    line-height: 2;
  }

  .pathways-section__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: clamp(2rem, 4vw, 4rem);
    row-gap: clamp(4.5rem, 8vw, 7rem);
  }

  .pathways-section__grid a {
    position: relative;
    display: grid;
    grid-template-rows: auto 1fr;
    min-width: 0;
    color: inherit;

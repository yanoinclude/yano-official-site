  /* The map character walks the island and turns around at each end. */
  .map-spot--yano {
    top: 0;
    left: 0;
    offset-path: path("M 408 456 C 480 426 564 418 648 426 C 720 433 768 410 816 365");
    offset-distance: 0%;
    offset-rotate: 0deg;
    offset-anchor: 50% 50%;
    animation: none;
    will-change: offset-distance;
  }

  .map-yano {
    width: auto;
    height: clamp(9.5rem, 14vw, 13rem);
    aspect-ratio: 260 / 264;
    overflow: hidden;
  }

  .map-yano::after { display: none; }

  .map-yano__sprite {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    transform-origin: 50% 85%;
    transition: none;
  }

  .map-spot--yano.is-returning .map-yano__sprite { transform: scaleX(-1); }

  .map-yano__frame {
    position: absolute;
    inset: 0;
    display: block;
    overflow: hidden;
    opacity: 0;
  }

  .map-spot--yano.is-walking .map-yano__frame--walk,
  .map-spot--yano.is-scratching .map-yano__frame--scratch,
  .map-spot--yano.is-settling .map-yano__frame--settle,
  .map-spot--yano.is-starting .map-yano__frame--settle,
  .map-spot--yano.is-idle .map-yano__frame--idle { opacity: 1; }

  .map-yano__frame img,
  .map-spot--yano:hover .map-yano__frame img,
  .map-spot--yano:focus-visible .map-yano__frame img,
  .map-spot--yano:active .map-yano__frame img {
    display: block;
    width: auto;
    max-width: none;
    height: 100%;
    filter: none;
    transform-origin: 0 0;
    transform: translate3d(0, 0, 0);
  }

  .map-yano__frame--walk img,
  .map-yano__frame--scratch img,
  .map-yano__frame--settle img { animation: none; }

  .map-spot--yano.is-walking .map-yano__frame--walk img {
    animation: island-yano-walk-frames 1s steps(12) infinite;
  }

  .map-spot--yano.is-scratching .map-yano__frame--scratch img {
    animation: island-yano-scratch-frames 1.2s steps(6) 1 both;
  }

  .map-spot--yano.is-settling .map-yano__frame--settle img {
    animation: island-yano-settle-frames 1.05s steps(3) 1 both;
  }

  .map-spot--yano.is-starting .map-yano__frame--settle img {
    animation: island-yano-settle-frames 0.65s steps(3) 1 reverse both;
  }

  @keyframes island-yano-walk-frames {
    to { transform: translate3d(-100%, 0, 0); }
  }

  @keyframes island-yano-scratch-frames {
    to { transform: translate3d(-100%, 0, 0); }
  }

  @keyframes island-yano-settle-frames {
    to { transform: translate3d(-100%, 0, 0); }
  }


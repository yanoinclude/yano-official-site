---
import TextLink from "@/components/ui/TextLink.astro";
import { homeContent } from "@/content/pages/home";
import { siteConfig } from "@/content/pages/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="愛媛県松山市・中島の風景とレモン"
  description={siteConfig.description}
>
  <section class="hero" aria-label="週末移住レモンのファーストビュー">
    <div class="hero__rail" aria-hidden="true">
      <span>{siteConfig.name}</span>
    </div>
    <div class="hero__track">
      <figure class="hero__image">
        <img src={homeContent.hero.image} alt={homeContent.hero.imageAlt} />
      </figure>
    </div>
    <p class="eyebrow hero__label">Nakajima, Matsuyama</p>
    <div class="hero__copy-block">
      <h1>
        <span>島の続きを、手入れする。</span>
      </h1>
    </div>
    <span class="hero__scroll" aria-hidden="true">scroll</span>
  </section>

  <section class="intro-facts-section reveal-section" id="introduction">
    <div
      class="intro-facts-section__message"
      aria-label={homeContent.intro.text}
    >
      {homeContent.intro.columns.map((column) => <p>{column}</p>)}
    </div>
    <figure class="intro-facts-section__image">
      <img src={homeContent.intro.image.src} alt={homeContent.intro.imageAlt} />
      <figcaption>{homeContent.intro.caption}</figcaption>
    </figure>
  </section>

  <section
    class="short-profile reveal-section"
    aria-labelledby="short-profile-title"
  >
    <div class="short-profile__summary">
      <p class="section-title__en">{homeContent.shortProfile.eyebrow}</p>
      <h2 id="short-profile-title">{homeContent.shortProfile.heading}</h2>
      <blockquote>{homeContent.shortProfile.quote}</blockquote>
      <ul>
        {
          homeContent.shortProfile.facts.map((fact) => <li>{fact}</li>)
        }
      </ul>
    </div>
    <div class="short-profile__body">
      {homeContent.shortProfile.body.map((paragraph) => <p>{paragraph}</p>)}
      <a
        class="short-profile__instagram"
        href={siteConfig.social.instagram}
        target="_blank"
        rel="noreferrer"
      >
        {homeContent.shortProfile.instagramLabel}
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </section>

  <section class="scenery-section reveal-section" id="scenery">
    <div class="scenery-place">
      <header class="scenery-place__heading">
        <h2>{homeContent.scenery.heading}</h2>
        <p>{homeContent.scenery.eyebrow}</p>
      </header>
      <div class="scenery-place__copy">
        {homeContent.scenery.body.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <figure class="scenery-place__photo">
        <img
          src={homeContent.scenery.featureImage.src}
          alt={homeContent.scenery.featureImageAlt}
        />
      </figure>
    </div>
  </section>

  <section class="timeline-section reveal-section" id="timeline">
    <header class="timeline-section__heading">
      <p class="section-title__en">{homeContent.timeline.eyebrow}</p>
      <h2>{homeContent.timeline.heading}</h2>
      <p>{homeContent.timeline.lead}</p>
    </header>

    <div class="timeline-chapters">
      {
        homeContent.timeline.groups.map((group) => (
          <details class="timeline-chapter">
            <summary>
              <span class="timeline-chapter__number">{group.number}</span>
              <span class="timeline-chapter__title">
                <strong>{group.title}</strong>
                <small>{group.body}</small>
              </span>
              <time>{group.period}</time>
              <span class="timeline-chapter__toggle" aria-hidden="true">
                ＋
              </span>
            </summary>
            <ol>
              {group.itemIndexes.map((itemIndex) => {
                const item = homeContent.timeline.items[itemIndex];
                return (
                  <li>
                    <time>{item.date}</time>
                    <div>
                      <h3>{item.title}</h3>
                      <p>{item.body}</p>
                    </div>
                  </li>
                );
              })}
            </ol>
          </details>
        ))
      }
    </div>

    <div class="timeline-more">
      <TextLink href="/story" variant="quiet">
        {homeContent.timeline.moreLabel}
      </TextLink>
    </div>

    <div class="timeline-current">
      <div class="timeline-current__intro">
        <p>{homeContent.timeline.current.date}</p>
        <h3>{homeContent.timeline.current.heading}</h3>
        <p>{homeContent.timeline.current.body}</p>
      </div>
      <div class="timeline-current__blocks">
        {
          homeContent.timeline.current.blocks.map((block) => (
            <a href={block.href} class="current-activity-card">
              <div>
                <p>{block.label}</p>
                <h4>{block.title}</h4>
              </div>
              <figure>
                <img src={block.image} alt={block.imageAlt} loading="lazy" />
              </figure>
              <span aria-hidden="true">↓</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section
    class="current-detail current-detail--lemon reveal-section"
    id="lemon-farm-detail"
  >
    <div class="current-detail__copy">
      <p class="section-title__en">
        {homeContent.currentActivities.lemonFarm.eyebrow}
      </p>
      <h2>{homeContent.currentActivities.lemonFarm.heading}</h2>
      <p class="current-detail__lead">
        {homeContent.currentActivities.lemonFarm.lead}
      </p>
      {
        homeContent.currentActivities.lemonFarm.body.map((paragraph) => (
          <p>{paragraph}</p>
        ))
      }
      <div class="current-detail__links">
        <TextLink href="/product" variant="quiet">
          {homeContent.currentActivities.lemonFarm.productLabel}
        </TextLink>
        <TextLink href={siteConfig.social.productInstagram} variant="quiet">
          {homeContent.currentActivities.lemonFarm.instagramLabel}
        </TextLink>
      </div>
    </div>
    <figure class="current-detail__hero">
      <img
        src={homeContent.currentActivities.lemonFarm.image}
        alt={homeContent.currentActivities.lemonFarm.imageAlt}
        loading="lazy"
      />
    </figure>
  </section>

  <section
    class="current-detail current-detail--kominka reveal-section"
    id="event-detail"
  >
    <div class="current-detail__copy">
      <p class="section-title__en">
        {homeContent.currentActivities.kominka.eyebrow}
      </p>
      <h2>{homeContent.currentActivities.kominka.heading}</h2>
      <p class="current-detail__community-copy">
        {homeContent.currentActivities.kominka.body}
      </p>
      <TextLink href="/events" variant="quiet">
        {homeContent.currentActivities.kominka.cta}
      </TextLink>
    </div>
    <figure class="current-detail__hero">
      <img
        src={homeContent.currentActivities.kominka.image}
        alt={homeContent.currentActivities.kominka.imageAlt}
        loading="lazy"
      />
    </figure>
  </section>

  <section
    class="gallery-preview reveal-section"
    aria-labelledby="gallery-title"
  >
    <header>
      <p class="section-title__en">{homeContent.gallery.eyebrow}</p>
      <h2 id="gallery-title">{homeContent.gallery.heading}</h2>
      <p>{homeContent.gallery.lead}</p>
    </header>
    <a
      class="gallery-preview__grid"
      href="/gallery"
      aria-label="島のギャラリーを見る"
    >
      {
        homeContent.gallery.items.slice(0, 4).map((item) => (
          <figure>
            <img src={item.image} alt={item.alt} loading="lazy" />
          </figure>
        ))
      }
    </a>
    <TextLink href="/gallery" variant="quiet">
      {homeContent.gallery.cta}
    </TextLink>
  </section>

  <section
    class="columns-preview reveal-section"
    aria-labelledby="columns-title"
  >
    <header>
      <div>
        <p class="section-title__en">{homeContent.columns.eyebrow}</p>
        <h2 id="columns-title">{homeContent.columns.heading}</h2>
      </div>
      <p>{homeContent.columns.lead}</p>
    </header>

    <div class="columns-preview__grid">
      {
        homeContent.columns.items.map((item) => (
          <article class="column-card">
            <a href={`/columns/${item.slug}/`}>
              <figure>
                <img src={item.image} alt={item.imageAlt} loading="lazy" />
              </figure>
              <div class="column-card__copy">
                <p>{item.category}</p>
                <h3>{item.title}</h3>
                <span>{item.excerpt}</span>
              </div>
            </a>
          </article>
        ))
      }
    </div>

    <TextLink href="/columns" variant="quiet">
      {homeContent.columns.cta}
    </TextLink>
  </section>

  <section class="product-section reveal-section" id="product">
    <figure class="product-section__image">
      <img
        src={homeContent.product.image}
        alt={homeContent.product.imageAlt}
        loading="lazy"
      />
    </figure>
    <div class="product-section__text">
      <p class="section-title__en">{homeContent.product.eyebrow}</p>
      <h2>{homeContent.product.heading}</h2>
      <p class="product-section__lead">{homeContent.product.lead}</p>
      <p>{homeContent.product.body}</p>
      <TextLink href={homeContent.product.href} variant="quiet">
        {homeContent.product.cta}
      </TextLink>
    </div>
  </section>

  <section class="news-section reveal-section" id="news">
    <div class="news-section__inner">
      <div>
        <p class="section-title__en">{homeContent.news.eyebrow}</p>
        <h2>{homeContent.news.heading}</h2>
      </div>
      <div class="news-list">
        {
          homeContent.news.items.map((item) => (
            <a href={item.href}>
              <time datetime={item.date.replaceAll(".", "-")}>{item.date}</time>
              <span>{item.title}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section
    class="closing-section reveal-section"
    aria-label="クロージングメッセージ"
  >
    <figure>
      <img src={homeContent.closing.image} alt={homeContent.closing.imageAlt} />
    </figure>
    <div>
      <div class="closing-section__body">
        <p>この島に、帰ってこられる風景を。</p>
      </div>
    </div>
  </section>

  <script>
    const revealTargets = document.querySelectorAll(".reveal-section");

    if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.setAttribute("data-in-view", "true");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 },
      );

      revealTargets.forEach((target) => observer.observe(target));
    } else {
      revealTargets.forEach((target) =>
        target.setAttribute("data-in-view", "true"),
      );
    }
  </script>
</BaseLayout>

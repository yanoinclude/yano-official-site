  .place-section__hero {
    position: relative;
    z-index: 1;
    isolation: isolate;
    margin-block: clamp(2.5rem, 3vw, 3rem) 0;
  }

  .place-section__hero-white {
    position: absolute;
    top: 50%;
    right: calc((100% - 100vw) / 2);
    bottom: 0;
    z-index: -1;
    width: 72vw;
    background: #fffdf6;
  }

  .place-section__hero img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 7.5;
    object-fit: cover;
    object-position: center 54%;
  }

  .place-section__hero figcaption {
    position: absolute;
    right: clamp(1rem, 3vw, 2.5rem);
    bottom: clamp(1rem, 3vw, 2rem);
    max-width: 28rem;
    padding: 0.55rem 0.75rem;
    background: rgb(255 253 246 / 88%);
    color: #2e4568;
    font-size: 0.75rem;
    line-height: 1.6;
  }

  .place-section__stories {
    position: relative;
    z-index: 1;
    display: grid;
    isolation: isolate;
    gap: clamp(7rem, 12vw, 12rem);
    margin-top: clamp(7rem, 12vw, 12rem);
  }

  .place-section__white-block {
    position: absolute;
    top: calc(-1 * clamp(7rem, 12vw, 12rem));
    right: calc((100% - 100vw) / 2);
    z-index: -1;
    width: 72vw;
    height: calc(75% + clamp(7rem, 12vw, 12rem) + 2px);
    background: #fffdf6;

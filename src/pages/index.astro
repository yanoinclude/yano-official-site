---
import { placeholderImages, siteConfig } from "@/content/pages/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
import MobileYanoJourney from "@/components/animation/MobileYanoJourney.astro";
import islandUserCutout from "@/assets/images/home/island-user-cutout.png";
import kominkaCutout from "@/assets/images/home/kominka-map-cutout.png";
import lemonJuiceDisplay from "@/assets/images/home/lemon-juice-display.webp";
import lemonTreeCutout from "@/assets/images/home/lemon-tree-storybook-cutout.png";
import nakajimaFerryCutout from "@/assets/images/home/nakajima-ferry-cutout.png";
import nakajimaBiyoriFeature from "@/assets/images/intro-feature/nakajima-biyori-feature.png";
import weekendLemonFeature from "@/assets/images/intro-feature/weekend-lemon-feature.png";
import aboutYanoLemonGrove from "@/assets/images/about-yano-lemon-grove.jpg";
import rankingLemonJuice from "@/assets/images/home/ranking-lemon-juice.jpeg";
import rankingKominkaEvent from "@/assets/images/home/ranking-kominka-event.jpeg";
import rankingMarche from "@/assets/images/home/ranking-marche.jpeg";
import noPlanThumbnail from "@/assets/images/projects/no-plan/vol-1.jpg";
import crowdfundingThumbnail from "@/assets/images/projects/crowdfunding.webp";
import nakajimaOverlook from "@/assets/images/scenery/nakajima-overlook.jpeg";
import nakajimaMap from "@/assets/images/scenery/nakajima-map.svg";
import recentLemon from "@/assets/images/generated/recent-lemon.png";

const activities = [
  {
    number: "01",
    category: "LEMON",
    targetId: "lemon-product",
    title: "レモンを育て、届ける",
    tags: ["#週末移住レモン"],
    body: "耕作放棄寸前だったレモン畑を引き継ぎ、週末ごとに手入れをしています。収穫した実は、果汁や商品にして島の外へ届けています。",
    image: rankingLemonJuice.src,
    alt: "週末移住レモン果汁の瓶が並ぶ様子",
  },
  {
    number: "02",
    category: "KOMINKA",
    targetId: "kominka",
    title: "古民家を直し、ひらく",
    tags: ["#古民家再生", "#クラウドファンディング"],
    body: "2円で購入した築100年の古民家を、仲間と少しずつ再生しています。島の内と外から、人が集まれる場所を目指しています。",
    image: rankingKominkaEvent.src,
    alt: "古民家で開かれた交流イベントの様子",
  },
  {
    number: "03",
    category: "COMMUNITY",
    targetId: "events",
    title: "人が集まるきっかけをつくる",
    tags: ["#イベント", "#お手伝い募集中"],
    body: "マルシェや収穫イベント、海掃除などに参加しています。島を知り、関わり始める小さなきっかけをつくっています。",
    image: rankingMarche.src,
    alt: "マルシェでレモン商品を販売する様子",
  },
];

const faqs = [
  {
    question: "なぜ古民家を直している？",
    answer:
      "大学時代に田舎を訪れ、その風景や人の暮らしに魅力を感じる一方、人口減少や高齢化によって、地域の営みが失われていく現実も知りました。地域活性化という大きなことではなく、まずは目の前にある風景と関わり続けたい。そんな思いから、中島で受け取った築100年の古民家を、人が集まり、一緒に手を動かせる場所へ少しずつ直しています。",
  },
  {
    question: "なぜレモン畑を管理している？",
    answer:
      "古民家再生でお世話になった近所の農家さんが体調を崩し、管理できなくなった約100本のレモンの木がありました。すべて伐採すると聞き、「この風景を残せるなら」とお願いし、できる範囲で引き継ぐことにしました。農家さんに教わりながら、週末に草刈りや剪定、収穫を続けています。",
  },
  {
    question: "収穫したレモンはどうしている？",
    answer:
      "収穫したレモンは、そのまま販売するだけでなく、畑の背景や島での取り組みも一緒に届けたいと考え、果汁などの商品にしています。現在は「週末移住レモン」として商品化し、オンラインショップからご覧いただけます。",
    link: { label: "週末移住レモンを見る", href: "/product" },
  },
  {
    question: "島へ行ってみたいときは？",
    answer:
      "中島には、松山の港から船で訪れることができます。古民家やレモン畑、島で活動する人たちに興味がある方は、InstagramのDMからご連絡ください。日程が合えば、島をご案内したり、面白い活動をしている人をご紹介したりします。",
    link: { label: "Instagramで連絡する", href: siteConfig.social.instagram },
  },
  {
    question: "最新情報はどこで見られる？",
    answer:
      "畑や古民家の様子、イベントのお知らせなど、日々の活動はInstagramで更新しています。まずは、週末ごとの島の様子をのぞいてみてください。",
    link: { label: "Instagramを見る", href: siteConfig.social.instagram },
  },
];

const pathways = [
  {
    label: "味見してみる",
    category: "PRODUCT",
    title: "週末移住レモン",
    body: "島の暮らしを少し味わう、レモン果汁と商品ページへ。",
    href: "/product",
    image: lemonJuiceDisplay.src,
    alt: "レモンと一緒に並ぶ週末移住レモン果汁",
  },
  {
    label: "直してきた記録を見る",
    category: "PROJECT",
    title: "古民家再生",
    body: "築100年の古民家を仲間と直してきたクラウドファンディングの記録へ。",
    href: "https://for-good.net/project/1001493/activity",
    image: crowdfundingThumbnail.src,
    alt: "古民家再生クラウドファンディングのサムネイル",
  },
  {
    label: "島のことを知る",
    category: "WEBSITE",
    title: "中島日和",
    body: "中島の柑橘や島の暮らしを届けるウェブサイトへ。",
    href: "https://nakajima-biyori.com/",
    image: placeholderImages.island,
    alt: "瀬戸内海に浮かぶ中島の風景",
  },
  {
    label: "活動を映像で見る",
    category: "YOUTUBE",
    title: "No Plan Project",
    body: "2円で買った築100年の古民家を、仲間と再生していく全9話の記録へ。",
    href: "/no-plan-project",
    image: noPlanThumbnail.src,
    alt: "ヤノッチのNo Plan Project vol.1の動画サムネイル",
  },
];
---

<BaseLayout
  title="矢野、週末移住中。"
  description="平日は松山で働き、週末は中島へ。古民家を直し、レモンを育て、島に人が集まるきっかけをつくる、矢野さとしの活動を紹介します。"
>
  <section class="weekend-hero" aria-label="中島での活動マップ">
    <h1 class="site-name">矢野、週末移住中。</h1>
    <p class="hero-introduction">
      平日は働き、週末は船で中島へ。古民家とレモンを手入れしながら、島との新しい関わり方をつくっています。
    </p>
    <div class="island-map" aria-label="中島での活動マップ" data-yano-island>
      <img
        class="hero-ferry"
        src={nakajimaFerryCutout.src}
        alt=""
        loading="eager"
        decoding="async"
        aria-hidden="true"
      />
      <img
        class="island-map__art"
        src={islandUserCutout.src}
        alt=""
        loading="eager"
        decoding="async"
      />
      <svg class="island-map__base" viewBox="0 0 1200 760" aria-hidden="true">
        <defs>
          <filter id="roughLine">
            <feTurbulence
              type="fractalNoise"
              baseFrequency="0.017"
              numOctaves="2"
              seed="11"></feTurbulence>
            <feDisplacementMap in="SourceGraphic" scale="1.8"
            ></feDisplacementMap>
          </filter>
          <pattern
            id="paperSpeckles"
            width="42"
            height="42"
            patternUnits="userSpaceOnUse"
          >
            <circle cx="5" cy="9" r="0.9"></circle>
            <circle cx="28" cy="17" r="0.7"></circle>
            <circle cx="17" cy="34" r="0.8"></circle>
            <circle cx="38" cy="37" r="0.6"></circle>
          </pattern>
        </defs>
        <rect class="island-map__paper" width="1200" height="760"></rect>
        <path
          class="island-map__shape"
          d="M147 134C234 54 405 62 528 94c103 27 197-6 307 31 124 42 220 139 248 254 31 127-25 258-118 325-96 68-221 42-342 24-115-17-195 30-318 12-130-19-229-89-268-202-38-108 20-322 110-404Z"
        ></path>
        <path
          class="island-map__shore"
          d="M142 202c132-94 272-88 419-47 111 31 199-6 315 32 103 34 176 102 213 201"
        ></path>
        <path
          class="island-map__trail"
          d="M201 582c91-91 204-140 323-141 93 0 171 45 274 30 82-12 142-55 209-112"
        ></path>
        <path
          class="island-map__trail island-map__trail--small"
          d="M516 166c-30 88-12 155 56 209 53 43 70 92 51 147"></path>
        <g class="island-map__grass">
          <path
            d="M82 158c6-16 11-16 14 1M101 152c7-19 13-19 18-1M125 158c8-14 15-13 20 2"
          ></path>
          <path
            d="M228 96c5-13 10-13 14 0M247 91c8-15 15-15 19 1M274 94c5-11 11-11 16 1"
          ></path>
          <path
            d="M391 169c8-17 14-18 20-2M420 167c8-21 17-20 25 1M456 175c7-15 15-14 21 3"
          ></path>
          <path
            d="M690 95c7-15 14-16 19 0M719 92c8-18 17-17 24 1M752 98c6-13 13-12 18 1"
          ></path>
          <path
            d="M965 167c6-17 13-17 19 1M993 163c8-20 17-20 25 0M1030 170c7-14 14-14 20 1"
          ></path>
          <path
            d="M156 319c6-14 12-14 17 1M181 314c7-17 15-17 22 1M214 321c7-13 14-12 20 2"
          ></path>
          <path
            d="M342 349c7-16 14-16 20 0M371 345c9-19 18-19 25 1M407 354c6-12 14-12 20 2"
          ></path>
          <path
            d="M779 330c7-16 13-16 19 0M807 326c9-18 17-18 24 1M842 333c6-12 13-12 19 1"
          ></path>
          <path
            d="M1000 456c7-15 14-15 19 1M1028 452c8-19 17-18 24 1M1063 459c6-12 13-11 19 2"
          ></path>
          <path
            d="M103 520c7-15 13-15 19 1M132 515c9-19 18-18 25 1M169 523c7-12 14-11 20 2"
          ></path>
          <path
            d="M486 612c8-16 16-16 23 1M520 607c9-18 19-18 28 1M560 616c7-13 15-12 22 2"
          ></path>
          <path
            d="M753 629c6-16 13-16 19 0M782 624c9-20 18-19 25 1M819 632c7-13 14-12 20 2"
          ></path>
          <path
            d="M997 624c6-14 12-13 18 1M1022 618c8-18 16-18 23 0M1055 626c7-12 14-12 20 2"
          ></path>
          <path
            d="M270 677c6-13 12-13 18 1M296 671c8-16 16-16 23 1M329 679c6-12 13-11 19 2"
          ></path>
        </g>
        <g class="island-map__doodles">
          <path
            class="island-map__cat"
            d="M78 279l13-13 14 12 20-2 14-10 15 10M89 278c-4 19 8 31 27 29 18-2 26-13 22-30M105 289h.2M126 286h.2M64 285c-19-4-32-1-39 11"
          ></path>
          <path
            class="island-map__bird"
            d="M920 284c15-21 34-28 59-20 18 6 33 1 45-14M960 265c-1-18 7-30 25-35"
          ></path>
          <path
            class="island-map__leaf"
            d="M1096 500c-24-20-46-20-68-1 12 24 37 24 68 1Z"></path>
          <path
            class="island-map__leaf island-map__leaf--small"
            d="M184 470c-20-16-38-15-54 2 12 18 31 18 54-2Z"></path>
          <path
            class="island-map__lemon"
            d="M891 70c28-13 67-7 85 17-12 28-52 37-84 21-20-10-21-27-1-38Z"
          ></path>
          <path
            class="island-map__spark"
            d="M884 60c7-25 22-39 45-43M981 98c24 2 42 12 53 30"></path>
        </g>
        <g class="island-map__waves">
          <path d="M82 228c34-18 67 19 101 1 30-16 60 6 90 1"></path>
          <path d="M912 128c34-18 69 18 103 0 29-15 58 6 88 2"></path>
          <path d="M935 678c34-18 69 18 103 0 29-15 58 6 88 2"></path>
          <path d="M34 665c34-18 68 17 102 0 29-15 58 6 88 2"></path>
        </g>
      </svg>

      <a
        class="map-spot map-spot--yano is-walking"
        href="#profile"
        aria-label="ページ内のヤノのプロフィールへ"
        data-island-yano
      >
        <span class="map-yano" aria-hidden="true">
          <span class="map-yano__sprite">
            <span class="map-yano__frame map-yano__frame--walk">
              <img
                src="/images/animation/yano-walk-sprite-12frames-v3.png"
                alt=""
                width="3120"
                height="264"
                loading="eager"
                decoding="async"
              />
            </span>
            <span class="map-yano__frame map-yano__frame--scratch">
              <img
                src="/images/animation/yano-scratch-sprite-6frames-v3.png"
                alt=""
                width="1560"
                height="264"
                loading="eager"
                decoding="async"
              />
            </span>
            <span class="map-yano__frame map-yano__frame--settle">
              <img
                src="/images/animation/yano-settle-sprite-3frames-v3.png"
                alt=""
                width="780"
                height="264"
                loading="eager"
                decoding="async"
              />
            </span>
            <span class="map-yano__frame map-yano__frame--idle">
              <img
                src="/images/animation/yano-idle-v3.png"
                alt=""
                width="260"
                height="264"
                loading="eager"
                decoding="async"
              />
            </span>
          </span>
        </span>
        <span>ヤノ</span>
      </a>
      <a
        class="map-spot map-spot--house"
        href="#kominka"
        aria-label="古民家の再生活動を見る"
      >
        <span class="map-landmark" aria-hidden="true">
          <img
            class="map-house"
            src={kominkaCutout.src}
            alt=""
            loading="eager"
            decoding="async"
          />
        </span>
        <span class="map-spot__connector" aria-hidden="true"></span>
        <span class="map-spot__label">
          <span>古民家をのぞく</span><span class="map-spot__arrow" aria-hidden="true">→</span>
        </span>
      </a>
      <a
        class="map-spot map-spot--farm"
        href="#lemon-product"
        aria-label="レモン畑と週末移住レモンを見る"
      >
        <span class="map-landmark" aria-hidden="true">
          <img
            class="map-farm"
            src={lemonTreeCutout.src}
            alt=""
            loading="eager"
            decoding="async"
          />
        </span>
        <span class="map-spot__connector" aria-hidden="true"></span>
        <span class="map-spot__label">
          <span>レモン畑をのぞく</span><span class="map-spot__arrow" aria-hidden="true">→</span>
        </span>
      </a>
    </div>
    <nav class="hero-mobile-actions" aria-label="島での活動を見る">
      <a href="#kominka"><span>古民家をのぞく</span><span aria-hidden="true">→</span></a>
      <a href="#lemon-product"><span>レモン畑をのぞく</span><span aria-hidden="true">→</span></a>
    </nav>
    <MobileYanoJourney />
  </section>

  <section class="weekend-intro reveal-section" id="about">
    <span
      class="weekend-intro__layer weekend-intro__layer--black"
      aria-hidden="true"></span>
    <span
      class="weekend-intro__layer weekend-intro__layer--yellow"
      aria-hidden="true"></span>
    <span
      class="weekend-intro__layer weekend-intro__layer--white"
      aria-hidden="true"></span>
    <div class="weekend-intro__inner content-shell">
      <div class="weekend-intro__paper weekend-intro__paper--first">
        <div class="weekend-intro__paper-inner">
          <header class="weekend-intro__heading">
            <p class="weekend-intro__label">WHY WEEKEND?</p>
            <h2>週末移住という暮らし</h2>
            <p class="weekend-intro__lead">
              週末だけ島へ通う、僕なりの田舎との関わり方
            </p>
          </header>
          <article class="weekend-intro__story">
          <figure>
            <img
              src={nakajimaBiyoriFeature.src}
              alt="レモン畑で過ごすヤノと、中島の日々をまとめた特集ビジュアル"
              loading="lazy"
              decoding="async"
            />
          </figure>
          <h3>今の暮らしを、手放さない。</h3>
          <p>仕事も、今の暮らしも、無理に手放さなくていい。平日は松山で働き、週末だけ船に乗って中島へ。僕の田舎暮らしは、いきなり移住するのではなく、通うことから始まりました。</p>
          </article>
        </div>
      </div>
      <div class="weekend-intro__paper weekend-intro__paper--second">
        <div class="weekend-intro__paper-inner">
          <article class="weekend-intro__story">
          <figure>
            <img
              src={weekendLemonFeature.src}
              alt="週末移住レモン果汁と、島の古民家から生まれたブランドの特集ビジュアル"
              loading="lazy"
              decoding="async"
            />
          </figure>
          <h3>島も、暮らしの一部になった</h3>
          <p>古民家を直し、レモンを育て、島の人たちと時間を過ごす。毎日住んでいなくても、少しずつ関わりを重ねることで、島はもうひとつの暮らしの場所になっていきました。</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="activities-section reveal-section" id="activities">
    <div class="content-shell">
      <header class="ranking-section__heading">
        <p class="section-kicker">ACTIVITIES</p>
        <h2>島でしていること</h2>
      </header>
      <div class="activities-list">
        <div class="activities-section__grid">
          {
            activities.map((activity) => (
              <article
                id={activity.targetId}
                class="ranking-slide"
              >
                <span class="ranking-card__badge">{activity.number}</span>
                <div class="ranking-card">
                  <figure class="ranking-card__media">
                    <img
                      src={activity.image}
                      alt={activity.alt}
                      loading="lazy"
                    />
                  </figure>
                  <div class="ranking-card__content">
                    <p class="ranking-card__category">{activity.category}</p>
                    <h3>{activity.title}</h3>
                    <p>{activity.body}</p>
                    <p class="ranking-card__tags">
                      {activity.tags.map((tag) => (
                        <span>{tag}</span>
                      ))}
                    </p>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="profile-section reveal-section" id="profile">
    <div class="content-shell">
      <header class="profile-section__heading">
        <p class="section-kicker">PROFILE</p>
        <p>田舎を、もっと身近な選択肢に。</p>
      </header>
      <div class="profile-section__layout">
        <figure class="profile-section__photo">
          <img
            src={aboutYanoLemonGrove.src}
            alt="中島のレモン畑で笑顔を見せる矢野諭稔"
            loading="lazy"
            decoding="async"
          />
        </figure>
        <div class="profile-section__details">
          <article class="profile-section__primary">
            <h2>矢野諭稔 <span>（週末移住者）</span></h2>
            <p class="profile-section__name-en">Satoshi Yano</p>
            <p>
              平日は広告代理店で働きながら、週末は愛媛の離島・中島へ。築100年の古民家と100本のレモンを手入れし、移住だけではない田舎との関わり方を実践しています。
            </p>
          </article>
          <article class="profile-section__secondary">
            <h3>しとらすすたんどKominKa</h3>
            <p>
              築100年古民家の屋号を「しとらすすたんどKominKa」と命名。島の活動拠点として運営しています。不定期でイベントを開催し、週末はメンバーが古民家を管理しています。
            </p>
          </article>
          <a class="profile-section__more" href="/about">MORE</a>
        </div>
      </div>
    </div>
  </section>

  <section class="place-section reveal-section" id="nakajima">
    <header class="access-section__heading content-shell">
      <h2>ACCESS</h2>
      <p>橋のない島へ、船で約1時間。</p>
    </header>

    <div class="access-section__map">
      <div class="access-section__map-fallback">
        <img src={nakajimaMap.src} alt="四国北西部と中島の位置を示す地図" />
      </div>
      <iframe
        title="Googleマップで見る愛媛県松山市中島と周辺の航路"
        src="https://www.google.com/maps?q=33.9751781,132.619553&z=11&output=embed"
        loading="eager"
        allowfullscreen
        referrerpolicy="strict-origin-when-cross-origin"></iframe>
    </div>

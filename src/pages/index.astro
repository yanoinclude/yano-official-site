  .place-section__guide-copy {
    width: min(calc(100% - 3rem), 47rem);
    text-align: center;
  }

  .place-section__guide-copy p {
    margin: 0;
    color: #fff;
    font-size: clamp(1rem, 1.35vw, 1.18rem);
    font-weight: 500;
    line-height: 2.05;

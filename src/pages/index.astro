---
import { homeContent } from "@/content/pages/home";
import { placeholderImages, siteConfig } from "@/content/pages/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
import kominkaRoofRestoration from "@/assets/images/home/kominka-roof-restoration.webp";
import lemonJuiceDisplay from "@/assets/images/home/lemon-juice-display.webp";
import heroImg0776 from "@/assets/images/home/hero-img-0776.jpeg";

const activities = [
  {
    id: "house",
    label: "古民家再生・活用",
    eyebrow: "01 / PLACE",
    title: "古い家に、もう一度人の気配を。",
    body: "建物が持つ原型を大切にしながら、必要な部分を少しずつ手入れしています。滞在や交流、ものづくりが始まる場所を目指しています。",
    points: ["古民家の再生・活用", "改修作業への参加", "滞在・交流企画"],
    image: kominkaRoofRestoration.src,
    alt: "中島の古民家の屋根を改修する様子",
  },
  {
    id: "farm",
    label: "レモン農園",
    eyebrow: "02 / FARM",
    title: "眠りかけた畑に、実りを。",
    body: "使われなくなりそうな畑を引き継ぎ、草刈りや剪定、収穫など、季節に合わせた手入れを続けています。",
    points: ["レモン農園の管理", "収穫・農作業体験", "中島産柑橘の販売"],
    image: placeholderImages.farm,
    alt: "中島のレモン農園",
  },
  {
    id: "product",
    label: "商品づくり",
    eyebrow: "03 / PRODUCT",
    title: "島の実りに、届け方を。",
    body: "中島で採れたレモンを使い、島の風景や物語まで感じられる商品をつくっています。",
    points: ["週末移住レモン果汁", "柑橘商品の企画", "パッケージ・販売企画"],
    image: lemonJuiceDisplay.src,
    alt: "レモンと一緒に並ぶ週末移住レモン果汁",
  },
  {
    id: "media",
    label: "発信・地域企画",
    eyebrow: "04 / PROJECT",
    title: "島の今を、島の外へ。",
    body: "YouTubeやウェブサイト、イベントなどを通して、中島で暮らす人や活動、島の魅力を発信しています。",
    points: ["YouTubeでの情報発信", "ウェブサイト制作", "イベント・共同企画"],
    image: placeholderImages.repair,
    alt: "島の内外から人が集まり一緒に活動する様子",
  },
];

const works = [
  {
    category: "YOUTUBE",
    icon: "▶",
    title: "離島の空き家チャンネル",
    body: "古民家再生や中島での活動を、動画で記録・発信しています。",
    image: placeholderImages.repair,
    alt: "中島の古民家を改修する人たち",
    href: "https://www.youtube.com/playlist?list=PLcHrn5cVHOxJCUtJaAPvsJqQRTznh-FaT",
  },
  {
    category: "CROWDFUNDING",
    icon: "支",
    title: "古民家再生クラウドファンディング",
    body: "世界のアーティストと島の人が交流できる、新しい拠点づくりに挑戦しました。",
    image: kominkaRoofRestoration.src,
    alt: "中島の古民家再生プロジェクト",
    href: "https://for-good.net/project/1001493",
  },
  {
    category: "WEBSITE",
    icon: "↗",
    title: "中島日和",
    body: "中島の柑橘や島の暮らしを届けるウェブサイトを制作しました。",
    image: placeholderImages.island,
    alt: "瀬戸内海に浮かぶ中島の風景",
    href: "https://nakajima-biyori.com/",
  },
  {
    category: "PRODUCT / WEBSITE",
    icon: "＋",
    title: "週末移住レモン",
    body: "週末に島へ通いながら育てたレモンを届ける、商品ブランドとウェブサイトをつくりました。",
    image: placeholderImages.bottle,
    alt: "週末移住レモン果汁",
    href: "/product",
  },
];
---

<BaseLayout
  title="地域の宝を、現役に。"
  description="古民家やレモン畑を手入れし、島の内外の人が関われる場所をつくる、矢野さとしの活動を紹介します。"
>
  <section class="top-hero" aria-labelledby="hero-title">
    <div class="top-hero__intro">
      <h1 id="hero-title">島の続きを、手入れする。</h1>
      <div class="top-hero__activities" aria-label="主な活動">
        <div>
          <span>築100年の家を、もう一度現役に</span>
          <strong>古民家再生</strong>
        </div>
        <div>
          <span>受け継いだ木を、次の季節へ</span>
          <strong>レモン農園</strong>
        </div>
        <div>
          <span>島の内と外に、関わりしろを</span>
          <strong>地域活動</strong>
        </div>
      </div>
      <p>
        私は、週末だけ島に通いながら、古民家再生とレモン畑の手入れを通して、人と島をつなぐ活動をしています。
      </p>
    </div>
    <figure class="top-hero__visual">
      <img src={heroImg0776.src} alt="中島のレモン畑で収穫を楽しむ人たち" />
    </figure>
  </section>

  <section class="profile content-shell reveal-section" id="about">
    <div class="profile__intro">
      <p class="section-kicker">ABOUT YANO</p>
      <h2>
        週末だけ、<br />
        <span>ちょっと</span>島に移住する。
      </h2>
      <div class="profile__copy">
        <p>
          平日は広告の仕事をしながら、<br />
          週末は愛媛県松山市の離島・中島へ。
        </p>
        <p>
          築100年の古民家と、100本のレモンの木を受け継ぎ、<br />
          少しずつ手を入れながら、島に人が集まるきっかけをつくっています。
        </p>
        <p>
          古いものを新しく変えるのではなく、<br />
          残ってきた風景を活かしながら、<br />
          人、仕事、商品、次の担い手へとつなげていく活動です。
        </p>
      </div>
    </div>

    <div class="profile__themes">
      <article>
        <figure>
          <img
            src={kominkaRoofRestoration.src}
            alt="中島の古民家の屋根を改修する様子"
            loading="lazy"
          />
        </figure>
        <p>01 / PLACE</p>
        <h3>築100年の古民家を再生</h3>
        <span>人が集まり、滞在し、<br />新しい活動が始まる場所へ。</span>
      </article>
      <article>
        <figure>
          <img
            src={placeholderImages.farm}
            alt="中島のレモン農園"
            loading="lazy"
          />
        </figure>
        <p>02 / FARM</p>
        <h3>約100本のレモン農園</h3>
        <span>受け継いだ木を手入れし、<br />島の実りを次の世代へ。</span>
      </article>
    </div>

    <a class="pill-link" href="/about">矢野のことを知る</a>
  </section>

  <section class="capabilities reveal-section" id="services">
    <div class="content-shell">
      <header class="capabilities__heading">
        <h2>
          <span class="capabilities__heading-en" aria-hidden="true"
            >What I can <i>do</i></span
          >
          <span class="capabilities__heading-ja">私ができること</span>
        </h2>
        <p>
          古民家や畑を手入れするだけでなく、そこから生まれる場所、商品、体験、発信まで。<br
          />島の内と外をつなぐ活動を行っています。
        </p>
      </header>

      <div class="capability-tabs" role="tablist" aria-label="ヤノができること">
        {
          activities.map((activity, index) => (
            <button
              type="button"
              role="tab"
              id={`tab-${activity.id}`}
              aria-controls={`panel-${activity.id}`}
              aria-selected={index === 0 ? "true" : "false"}
              tabindex={index === 0 ? 0 : -1}
              data-activity-tab={activity.id}
            >
              {activity.label}
            </button>
          ))
        }
      </div>

      <div class="capability-panels">
        {
          activities.map((activity, index) => (
            <article
              role="tabpanel"
              id={`panel-${activity.id}`}
              aria-labelledby={`tab-${activity.id}`}
              hidden={index !== 0}
              data-activity-panel={activity.id}
            >
              <div class="capability-panel__copy">
                <p class="section-kicker">{activity.eyebrow}</p>
                <h3>{activity.title}</h3>
                <p>{activity.body}</p>
                <div>
                  <span>Recommend</span>
                  <ul>
                    {activity.points.map((point) => (
                      <li>{point}</li>
                    ))}
                  </ul>
                </div>
              </div>
              <figure>
                <img src={activity.image} alt={activity.alt} loading="lazy" />
              </figure>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="worked-on content-shell reveal-section" id="works">
    <header class="section-heading">
      <p class="section-kicker">WHAT WE WORKED ON</p>
      <h2>てがけてきたこと</h2>
    </header>

    <div class="worked-on__grid">
      {
        works.map((work) => (
          <a
            href={work.href}
            target={work.href.startsWith("http") ? "_blank" : undefined}
            rel={work.href.startsWith("http") ? "noreferrer" : undefined}
          >
            <figure>
              <img src={work.image} alt={work.alt} loading="lazy" />
              <span aria-hidden="true">{work.icon}</span>
            </figure>
            <p>{work.category}</p>
            <h3>{work.title}</h3>
            <div>
              <span>{work.body}</span>
              <i aria-hidden="true">↗</i>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="contact-panel reveal-section" id="contact">
    <img
      src={homeContent.closing.image}
      alt={homeContent.closing.imageAlt}
      loading="lazy"
    />
    <div class="contact-panel__shade"></div>
    <div class="contact-panel__copy">
      <p>PLEASE FEEL FREE TO CONTACT ME.</p>
      <h2>島に来る。<br />一緒に手を動かす。<br />レモンを味わう。</h2>
      <span>
        中島での活動や古民家、レモン農園に興味を持っていただけた方は、<br
        />お気軽にご連絡ください。
      </span>
      <div>
        <a href={`mailto:${siteConfig.contact.email}`}>お問い合わせ</a>
        <a href={siteConfig.social.instagram} target="_blank" rel="noreferrer"
          >Instagram</a
        >
      </div>
    </div>
  </section>

  <script>
    const tabs = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-activity-tab]"),
    );
    const panels = Array.from(
      document.querySelectorAll<HTMLElement>("[data-activity-panel]"),
    );

    const selectTab = (tab: HTMLButtonElement, moveFocus = false) => {
      const id = tab.dataset.activityTab;
      tabs.forEach((item) => {
        const selected = item === tab;
        item.setAttribute("aria-selected", String(selected));
        item.tabIndex = selected ? 0 : -1;
      });
      panels.forEach((panel) => {
        panel.hidden = panel.dataset.activityPanel !== id;
      });
      if (moveFocus) tab.focus();
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener("click", () => selectTab(tab));
      tab.addEventListener("keydown", (event) => {
        if (!["ArrowLeft", "ArrowRight", "Home", "End"].includes(event.key)) {
          return;
        }
        event.preventDefault();
        let nextIndex = index;
        if (event.key === "ArrowLeft") {
          nextIndex = (index - 1 + tabs.length) % tabs.length;
        }
        if (event.key === "ArrowRight") {
          nextIndex = (index + 1) % tabs.length;
        }
        if (event.key === "Home") nextIndex = 0;
        if (event.key === "End") nextIndex = tabs.length - 1;
        selectTab(tabs[nextIndex], true);
      });
    });

    const revealTargets = document.querySelectorAll(".reveal-section");
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      revealTargets.forEach((target) =>
        target.setAttribute("data-in-view", "true"),
      );
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.setAttribute("data-in-view", "true");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08 },
      );
      revealTargets.forEach((target) => observer.observe(target));
    }
  </script>
</BaseLayout>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  .content-shell {
    width: min(calc(100% - 8rem), 1120px);
    margin-inline: auto;
  }

  .top-hero {
    width: min(calc(100% - 6rem), 1440px);
    min-height: 0;
    margin-inline: auto;
    padding: clamp(3rem, 5vw, 4.5rem) clamp(2rem, 5vw, 5rem) 0;
    overflow: hidden;
    border-radius: 48% 48% 0 0 / 12% 12% 0 0;
    background: #f7f5e9;
    color: #30463b;
  }

  .contact-panel__shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(17, 30, 20, 0.58),
      rgba(17, 30, 20, 0.06) 72%
    );
  }

  .top-hero__intro {
    position: relative;
    z-index: 1;
    display: grid;
    justify-items: center;
    text-align: center;
  }

  .top-hero__intro h1 {
    margin: 0;
    font-family: var(--font-island-body);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: 0.04em;
  }

  .top-hero__activities {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, auto));
    gap: 0.75rem;
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
  }

  .top-hero__activities > div {
    display: grid;
    gap: 0.35rem;
  }

  .top-hero__activities span {
    font-size: 0.62rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .top-hero__activities strong {
    min-width: 9.8rem;
    padding: 0.7rem 1rem;
    border-radius: 0.45rem;
    background: #c9d9d7;
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    font-weight: 500;
    line-height: 1.2;
  }

  .top-hero__activities > div:nth-child(2) strong {
    background: #ded1be;
  }

  .top-hero__activities > div:nth-child(3) strong {
    background: #d8d1df;
  }

  .top-hero__intro > p {
    max-width: 44rem;
    margin: 2rem 0 0;
    font-size: 0.78rem;
    font-weight: 500;
    line-height: 1.9;
  }

  .top-hero__visual {
    position: relative;
    width: min(100%, 1180px);
    margin: clamp(2.5rem, 5vw, 4.5rem) auto 0;
    overflow: hidden;
    border-radius: 48% 48% 0 0 / 18% 18% 0 0;
    aspect-ratio: 1334 / 720;
    background: #d5ddd4;
  }

  .top-hero__visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 50%;
  }

  .section-kicker {
    margin: 0 0 1rem;
    color: var(--island-muted);
    font-family: var(--font-island-accent);
    font-size: 0.68rem;
    letter-spacing: 0.2em;
  }

  .section-heading h2,
  .profile h2 {
    margin: 0;
    font-family: var(--font-island-body);
    font-size: clamp(1.9rem, 2.8vw, 2.5rem);
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: 0.03em;
  }

  .section-heading > p:last-child {
    max-width: 44rem;
    margin: 1.5rem 0 0;
    font-size: 0.86rem;
    line-height: 2;
  }

  .profile {
    padding-block: clamp(7rem, 12vw, 11rem);
  }

  .profile__intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .profile__intro > .section-kicker {
    margin-bottom: 1.5rem;
  }

  .profile__intro > h2 {
    position: relative;
    z-index: 0;
    max-width: 18em;
    color: #30486e;
    font-size: clamp(2.1rem, 4vw, 3.8rem);
    font-weight: 600;
    line-height: 1.45;
    letter-spacing: 0.01em;
  }

  .profile__intro > h2 span {
    position: relative;
    display: inline-block;
  }

  .profile__intro > h2 span::before {
    position: absolute;
    z-index: -1;
    top: 50%;
    left: 46%;
    width: 1.9em;
    aspect-ratio: 1;
    border-radius: 50%;
    background: #f3cf61;
    content: "";
    transform: translate(-50%, -50%);
  }

  .profile__copy {
    max-width: 50rem;
    margin-top: clamp(3.5rem, 7vw, 6rem);
  }

  .profile__copy p {
    margin: 0;
    color: #30486e;
    font-size: clamp(0.84rem, 1.2vw, 1rem);
    font-weight: 600;
    line-height: 2.2;
  }

  .profile__copy p + p {
    margin-top: 0.65rem;
  }

  .profile__themes {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(3rem, 8vw, 8rem);
    margin-top: clamp(5rem, 9vw, 8rem);
  }

  .profile__themes figure {
    aspect-ratio: 4 / 3;
    margin: 0 0 1.5rem;
    overflow: hidden;
    background: #e6e7e2;
  }

  .profile__themes img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }

  .profile__themes article:hover img {
    transform: scale(1.025);
  }

  .profile__themes article > p,
  .worked-on__grid > a > p {
    margin: 0;
    color: var(--island-muted);
    font-size: 0.66rem;
    letter-spacing: 0.17em;
  }

  .profile__themes h3 {
    margin: 0.65rem 0 0.8rem;
    font-family: var(--font-island-body);
    font-size: 1.125rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .profile__themes article > span {
    font-size: 0.78rem;
    line-height: 1.85;
  }

  .pill-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: min(18rem, 100%);
    min-height: 3rem;
    margin: clamp(4rem, 7vw, 6rem) auto 0;
    border: 1px solid var(--island-text);
    border-radius: 999px;
    color: var(--island-text);
    font-size: 0.78rem;
    text-decoration: none;
    transition:
      background-color 0.3s ease,
      color 0.3s ease;
  }

  .pill-link:hover,
  .pill-link:focus-visible {
    background: var(--island-text);
    color: #fff;
  }

  .capabilities {
    padding: clamp(6rem, 10vw, 9rem) 0 0;
    overflow: hidden;
    background: #f5f1ed;
  }

  .capabilities__heading {
    text-align: center;
  }

  .capabilities__heading h2 {
    position: relative;
    display: grid;
    place-items: center;
    min-height: clamp(7rem, 13vw, 11rem);
    margin: 0;
  }

  .capabilities__heading-en {
    color: #e2e4e9;
    font-family: var(--font-island-accent);
    font-size: clamp(4rem, 10vw, 8.8rem);
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.06em;
    white-space: nowrap;
  }

  .capabilities__heading-en i {
    position: relative;
    z-index: 0;
    display: inline-block;
    color: #e2e4e9;
    font-style: normal;
  }

  .capabilities__heading-en i::before {
    position: absolute;
    z-index: -1;
    top: 50%;
    left: 50%;
    width: 1.45em;
    aspect-ratio: 1;
    border-radius: 50%;
    background: #f6cf68;
    content: "";
    transform: translate(-50%, -50%);
  }

  .capabilities__heading-ja {
    position: absolute;
    z-index: 1;
    color: #30486e;
    font-family: var(--font-island-body);
    font-size: clamp(1.65rem, 3.2vw, 2.65rem);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .capabilities__heading > p {
    max-width: 49rem;
    margin: clamp(2rem, 4vw, 3.5rem) auto 0;
    color: #30486e;
    font-size: 0.86rem;
    font-weight: 600;
    line-height: 2;
  }

  .capability-tabs {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.65rem;
    margin-top: clamp(4rem, 7vw, 6rem);
  }

  .capability-tabs button {
    min-height: 5.5rem;
    padding: 1rem 0.75rem;
    border: 0;
    border-radius: 1.4rem 1.4rem 0 0;
    background: #e0e1e6;
    color: #30486e;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.5;
    cursor: pointer;
    transition:
      background-color 0.25s ease,
      color 0.25s ease;
  }

  .capability-tabs button[aria-selected="true"] {
    background: #fffdf3;
    color: #30486e;
  }

  .capability-panels article {
    display: grid;
    grid-template-columns: minmax(20rem, 0.95fr) minmax(25rem, 1.05fr);
    gap: clamp(3rem, 7vw, 7rem);
    align-items: center;
    min-height: 38rem;
    padding: clamp(4rem, 7vw, 6.5rem) clamp(2rem, 5vw, 5rem);
    background: #fffdf3;
  }

  .capability-panels article[hidden] {
    display: none;
  }

  .capability-panel__copy h3 {
    max-width: 13em;

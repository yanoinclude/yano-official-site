  .empathy-section__body p,
  .concept-section__copy p,
  .place-section__copy p {
    margin: 0;
  }

  .empathy-section__body p + p,
  .concept-section__copy p + p {
    margin-top: 1.15rem;
  }

  .empathy-section {
    position: relative;
    width: 100vw;
    max-width: none;
    margin-inline: calc(50% - 50vw);
    padding: 4rem clamp(1.5rem, 6vw, 5rem) clamp(5rem, 8vw, 7rem);
    overflow: hidden;
    background: #36a9ee;
  }

  .empathy-section__stack {
    position: relative;
    width: min(100%, 68rem);
    margin-inline: auto;
  }


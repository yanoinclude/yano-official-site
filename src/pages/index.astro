  /* Hero map affordances: the landmark, dotted halo, connector and label form one link. */
  .map-spot--house,
  .map-spot--farm {
    gap: 0;
    min-width: clamp(13rem, 19vw, 17rem);
    padding: 1rem;
    cursor: pointer;
  }

  .map-spot--house { top: 73%; left: 35%; }
  .map-spot--farm { top: 66%; left: 61%; }

  .map-spot--house .map-landmark,
  .map-spot--farm .map-landmark {
    transition: transform 220ms ease, filter 220ms ease;
  }

  .map-spot--house .map-landmark::after,
  .map-spot--farm .map-landmark::after {
    position: absolute;
    inset: -9% -12%;
    z-index: 2;
    border: 3px dashed #f8dc42;
    border-radius: 49% 51% 46% 54% / 52% 45% 55% 48%;
    content: "";
    pointer-events: none;
    transform: rotate(-4deg);
    transition: border-color 220ms ease, filter 220ms ease, transform 220ms ease;
  }

  .map-spot--farm .map-landmark::after {
    inset: -7% -10%;
    transform: rotate(5deg);
  }

  .map-spot__connector {
    z-index: 2;
    display: block;
    width: 3px;
    height: clamp(0.65rem, 1.2vw, 1rem);
    margin-block: -0.08rem -0.05rem;
    border-radius: 999px;
    background: #f8dc42;
    transform: rotate(9deg);
    transform-origin: center;
  }

  .map-spot--farm .map-spot__connector { transform: rotate(-12deg); }

  .map-spot--house .map-spot__label,
  .map-spot--farm .map-spot__label {
    position: relative;
    z-index: 3;
    gap: 0.75rem;
    min-height: clamp(2.75rem, 3.5vw, 3.2rem);
    padding: 0.65rem clamp(1.15rem, 1.7vw, 1.55rem);
    border: 2.5px solid #1f3659;
    border-radius: 0.75rem 0.62rem 0.8rem 0.58rem;
    background: #fffdf8;
    color: #233f61;
    font-size: clamp(1rem, 1.3vw, 1.125rem);
    letter-spacing: 0.03em;
    box-shadow: 0.3rem 0.35rem 0 #f8dc42;
    transition: background-color 220ms ease, box-shadow 220ms ease, transform 220ms ease;
  }

  .map-spot__arrow {
    display: inline-block;
    font-size: 1.18em;
    line-height: 1;
    transition: transform 220ms ease;
  }

  .map-spot--house:focus-visible,
  .map-spot--farm:focus-visible {
    outline: 4px solid #fffdf8;
    outline-offset: 3px;
    filter: drop-shadow(0 0 0.15rem #233f61);
  }

  .map-spot--house:focus-visible .map-spot__label,
  .map-spot--farm:focus-visible .map-spot__label {
    background: #fff3a6;
    box-shadow: 0.42rem 0.48rem 0 #f8dc42;
    transform: translateY(-3px);
  }

  .map-spot--house:focus-visible .map-landmark,
  .map-spot--farm:focus-visible .map-landmark {
    filter: drop-shadow(0 0 0.28rem #fffdf8) drop-shadow(0 0 0.22rem #f8dc42);
    transform: scale(1.045);
  }

  .map-spot--house:focus-visible .map-landmark::after,
  .map-spot--farm:focus-visible .map-landmark::after {
    border-color: #ffe449;
    filter: drop-shadow(0 0 0.2rem rgb(255 228 73 / 60%));
    transform: rotate(0deg) scale(1.025);
  }

  .map-spot--house:focus-visible .map-spot__arrow,
  .map-spot--farm:focus-visible .map-spot__arrow { transform: translateX(4px); }

  @media (hover: hover) and (pointer: fine) {
    .map-spot--house:hover,
    .map-spot--farm:hover {
      outline: 0;
      filter: none;
      transform: translate(-50%, -50%) rotate(var(--tilt, 0deg));
    }

    .map-spot--house:hover .map-spot__label,
    .map-spot--farm:hover .map-spot__label {
      background: #fff3a6;
      box-shadow: 0.42rem 0.48rem 0 #f8dc42;

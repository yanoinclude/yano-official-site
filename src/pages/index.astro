    border-radius: 52% 48% 56% 44% / 46% 52% 48% 54%;
    background: rgb(255 253 248 / 92%);
    color: #233f61;
    font-size: 0.96rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    white-space: nowrap;
    box-shadow: 0 2px 0 rgb(47 93 67 / 10%);
  }

  .map-spot--yano > span:last-child {
    padding: 0.2rem 0.5rem;
    border: 1.5px solid #2f5d43;
    border-radius: 52% 48% 56% 44% / 46% 52% 48% 54%;
    background: rgb(255 253 248 / 78%);
    box-shadow: 0 2px 0 rgb(47 93 67 / 10%);
  }

  .map-spot--yano {
    top: 55%;
    left: 37%;
    --tilt: -5deg;
    min-width: 6.6rem;
    animation: yano-stroll 9.5s ease-in-out infinite;
    transform-origin: 50% 92%;
  }

  .map-spot--house {
    top: 74%;
    left: 37%;
    --tilt: 3deg;
  }

  .map-spot--farm {
    top: 66%;
    left: 59%;
    --tilt: -3deg;
  }

  .map-farm {
    position: relative;
    display: block;
    width: clamp(2.4rem, 4.2vw, 3.6rem);
    height: clamp(2.4rem, 4.2vw, 3.6rem);
    border: 2.5px solid #2f5d43;
    background: #fffdf8;
    box-shadow: 0.18rem 0.22rem 0 rgb(47 93 67 / 9%);
  }

  .map-yano {
    position: absolute;
    left: 50%;
    bottom: 1.9rem;
    display: block;
    width: clamp(5.2rem, 8.2vw, 7.6rem);
    aspect-ratio: 485 / 900;
    filter: drop-shadow(0.22rem 0.3rem 0 rgb(47 93 67 / 16%));
    transform: translateX(-50%);
    transform-origin: 50% 90%;
  }

  .map-yano::after {
    position: absolute;
    right: -0.35rem;
    bottom: 0.5rem;
    width: 1.2rem;
    height: 0.55rem;
    border-bottom: 2px solid #2f5d43;
    border-radius: 50%;
    content: "";
    opacity: 0.25;
    transform: rotate(-8deg);
  }

  .map-yano img {
    display: block;
    width: 100%;
    height: auto;
    animation: yano-step 0.82s ease-in-out infinite;
    transform-origin: 50% 90%;
    transition:
      filter 0.2s ease,
      transform 0.2s ease;
  }

  .map-spot--yano:hover,
  .map-spot--yano:focus-visible {
    animation-play-state: paused;
    filter: drop-shadow(0 10px 0 rgb(47 93 67 / 12%));
    transform: translate(-50%, -58%) translate(0.28rem, -0.18rem) rotate(-9deg);
  }

  .map-spot--yano:hover .map-yano img,
  .map-spot--yano:focus-visible .map-yano img {
    animation-duration: 0.42s;
    filter: saturate(1.08);
    transform: rotate(-3deg) translateY(-0.18rem);
  }

  .map-spot--yano:active .map-yano img {
    transform: rotate(2deg) translateY(0.1rem) scale(0.97);
  }

  .map-house {
    display: block;
    width: clamp(10.5rem, 17vw, 17rem);
    max-width: none;
    height: auto;
    border: 0;
    background: transparent;
    filter: drop-shadow(0 0.18rem 0.22rem rgb(47 93 67 / 14%));
    transition:
      transform 0.2s ease,
      filter 0.2s ease;
  }

  .map-farm {
    display: block;
    width: clamp(10rem, 16vw, 16.5rem);
    max-width: none;
    height: auto;
    border: 0;
    background: transparent;
    filter: drop-shadow(0 0.18rem 0.22rem rgb(47 93 67 / 14%));
  }

  .map-spot--house:hover,
  .map-spot--house:focus-visible,
  .map-spot--farm:hover,
  .map-spot--farm:focus-visible {
    outline: 0;
    outline-offset: 0;
    scale: 1.05;
    translate: 0 -0.35rem;
    filter: none;
  }

  .map-spot--farm:hover .map-farm,
  .map-spot--farm:focus-visible .map-farm {
    filter: drop-shadow(0 0.45rem 0.5rem rgb(35 63 97 / 18%));
    transform: translateY(-0.08rem);
  }

  @keyframes landmark-pop {
    from {
      opacity: 0;
      scale: 0.72;
    }

    to {
      opacity: 1;
      scale: 1;
    }
  }

  @keyframes yano-stroll {
    0%,
    100% {
      transform: translate(-50%, -50%) translate(0, 0) rotate(-5deg);
    }

    24% {
      transform: translate(-50%, -50%) translate(0.35rem, -0.35rem)
        rotate(-7deg);
    }

    50% {
      transform: translate(-50%, -50%) translate(0.95rem, 0.1rem) rotate(-3deg);
    }

    74% {
      transform: translate(-50%, -50%) translate(0.35rem, 0.3rem) rotate(-6deg);
    }
  }

  @keyframes ferry-float {
    0%,
    100% {
      transform: translate(0, 0) rotate(-2deg);
    }

    30% {
      transform: translate(0.35rem, -0.45rem) rotate(-0.5deg);
    }

    58% {
      transform: translate(0.75rem, 0.12rem) rotate(1deg);
    }

    80% {
      transform: translate(0.25rem, 0.35rem) rotate(-1deg);
    }
  }

  @keyframes yano-step {
    0%,
    100% {
      transform: translateY(0) rotate(-1.5deg);
    }

    50% {
      transform: translateY(-0.26rem) rotate(2deg);
    }
  }


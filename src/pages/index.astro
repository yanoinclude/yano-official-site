---
import { placeholderImages, siteConfig } from "@/content/pages/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
import islandUserCutout from "@/assets/images/home/island-user-cutout.png";
import lemonJuiceDisplay from "@/assets/images/home/lemon-juice-display.webp";
import nakajimaFerryCutout from "@/assets/images/home/nakajima-ferry-cutout.png";
import seaWaveCutout from "@/assets/images/home/sea-wave-cutout.png";
import yanoWalkingCutout from "@/assets/images/home/yano-walking-cutout.png";
import noPlanThumbnail from "@/assets/images/projects/no-plan/vol-1.jpg";
import crowdfundingThumbnail from "@/assets/images/projects/crowdfunding.webp";
import nakajimaMap from "@/assets/images/scenery/nakajima-map.svg";

const seaWaves = [
  { x: 6, y: 15, size: 6.2, rotate: -4, opacity: 0.55 },
  { x: 24, y: 8, size: 4.4, rotate: 3, opacity: 0.42 },
  { x: 43, y: 13, size: 5.3, rotate: -2, opacity: 0.5 },
  { x: 67, y: 7, size: 4.8, rotate: 5, opacity: 0.44 },
  { x: 84, y: 16, size: 6.6, rotate: -5, opacity: 0.58 },
  { x: 13, y: 29, size: 4.7, rotate: 4, opacity: 0.46 },
  { x: 34, y: 25, size: 6.8, rotate: -3, opacity: 0.54 },
  { x: 57, y: 31, size: 4.2, rotate: 6, opacity: 0.4 },
  { x: 76, y: 28, size: 5.6, rotate: 2, opacity: 0.52 },
  { x: 91, y: 36, size: 4.3, rotate: -6, opacity: 0.43 },
  { x: 4, y: 45, size: 5.1, rotate: 5, opacity: 0.48 },
  { x: 22, y: 42, size: 4.5, rotate: -4, opacity: 0.45 },
  { x: 47, y: 48, size: 6.4, rotate: 3, opacity: 0.56 },
  { x: 69, y: 43, size: 4.6, rotate: -5, opacity: 0.42 },
  { x: 86, y: 51, size: 6.1, rotate: 4, opacity: 0.53 },
  { x: 10, y: 63, size: 6.5, rotate: -3, opacity: 0.55 },
  { x: 31, y: 59, size: 4.1, rotate: 6, opacity: 0.4 },
  { x: 54, y: 66, size: 5.7, rotate: -4, opacity: 0.51 },
  { x: 74, y: 61, size: 4.9, rotate: 2, opacity: 0.46 },
  { x: 92, y: 69, size: 4.4, rotate: -6, opacity: 0.44 },
  { x: 5, y: 81, size: 4.6, rotate: 4, opacity: 0.45 },
  { x: 25, y: 76, size: 6.3, rotate: -2, opacity: 0.54 },
  { x: 46, y: 84, size: 4.3, rotate: 5, opacity: 0.41 },
  { x: 68, y: 78, size: 5.5, rotate: -5, opacity: 0.5 },
  { x: 86, y: 87, size: 6.7, rotate: 3, opacity: 0.57 },
];

const activities = [
  {
    number: "01",
    targetId: "kominka",
    title: "古民家を直す",
    body: "2円で譲り受けた築100年の古民家を、泊まる、集まる、手を動かす場所へ。仲間や島の人に教わりながら、少しずつ手入れしています。",
    image: placeholderImages.house,
    alt: "中島の築100年の古民家を改修する様子",
  },
  {
    number: "02",
    targetId: "lemon-product",
    title: "レモンを育てる",
    body: "100本のレモンの木を任され、週末に畑へ通っています。草刈り、剪定、収穫まで、できる範囲で木と実の行き先を守っています。",
    image: placeholderImages.farmer,
    alt: "中島のレモン畑で木を手入れする様子",
  },
  {
    number: "03",
    targetId: "events",
    title: "人が集まるきっかけをつくる",
    body: "海掃除、マルシェ、収穫イベント、アロマ蒸留体験。島に行ってみたい人が、少し関われる入口をつくっています。",
    image: placeholderImages.repair,
    alt: "島の内外から人が集まり一緒に活動する様子",
  },
];

const faqs = [
  {
    question: "中島ってどこにある？",
    answer:
      "愛媛県松山市の沖にある、瀬戸内海の島です。松山の港から船で向かうことができ、柑橘畑、海、古民家、人の暮らしが近くにあります。",
  },
  {
    question: "なぜ古民家を直している？",
    answer:
      "島で受け取った一軒の家を、もう一度人が集まり、泊まり、手を動かせる場所にしたかったからです。古民家は、島との関わりを始めるための小さな拠点です。",
  },
  {
    question: "レモン畑はどう管理している？",
    answer:
      "平日は松山や東京で働き、週末に中島へ通って草刈り、剪定、収穫などを行っています。農家さんや周囲の人に教わりながら、100本の木を少しずつ手入れしています。",
  },
  {
    question: "レモン果汁は買える？",
    answer:
      "はい。週末に手入れして収穫した中島のレモンから、週末移住レモン果汁をつくっています。商品ページから詳細を見ることができます。",
  },
  {
    question: "島に行くことはできる？",
    answer:
      "中島には訪れることができます。島の情報は中島日和、ヤノの活動やイベント案内はInstagramで更新しています。",
  },
  {
    question: "最新情報はどこで見られる？",
    answer:
      "日々の活動、畑や古民家の様子、イベント案内はInstagramで更新しています。まずは近況を見るだけでも歓迎です。",
  },
];

const pathways = [
  {
    label: "味見してみる",
    title: "週末移住レモン",
    body: "島の暮らしを少し味わう、レモン果汁と商品ページへ。",
    href: "/product",
    image: lemonJuiceDisplay.src,
    alt: "レモンと一緒に並ぶ週末移住レモン果汁",
  },
  {
    label: "直してきた記録を見る",
    title: "古民家再生",
    body: "築100年の古民家を仲間と直してきたクラウドファンディングの記録へ。",
    href: "https://for-good.net/project/1001493/activity",
    image: crowdfundingThumbnail.src,
    alt: "古民家再生クラウドファンディングのサムネイル",
  },
  {
    label: "島のことを知る",
    title: "中島日和",
    body: "中島の柑橘や島の暮らしを届けるウェブサイトへ。",
    href: "https://nakajima-biyori.com/",
    image: placeholderImages.island,
    alt: "瀬戸内海に浮かぶ中島の風景",
  },
  {
    label: "活動を追いかける",
    title: "Instagram",
    body: "畑、古民家、イベントの近況をInstagramで更新中。",
    href: siteConfig.social.instagram,
    image: placeholderImages.table,
    alt: "島の食卓を囲む人たち",
  },
];

const works = [
  {
    category: "YOUTUBE",
    title: "ヤノッチのNo Plan Project",
    body: "2円で買った築100年の古民家を、仲間と一緒に再生していく全9話の記録です。",
    image: noPlanThumbnail.src,
    alt: "ヤノッチのNo Plan Project vol.1の動画サムネイル",
    href: "/no-plan-project",
  },
  {
    category: "CROWDFUNDING",
    title: "古民家再生クラウドファンディング",
    body: "世界のアーティストと島の人が交流できる、新しい拠点づくりに挑戦しました。",
    image: crowdfundingThumbnail.src,
    alt: "世界のアーティストとまちの人が交流できる新たな拠点をつくるクラウドファンディング",
    href: "https://for-good.net/project/1001493/activity",
  },
  {
    category: "WEBSITE",
    title: "中島日和",
    body: "中島の柑橘や島の暮らしを届けるウェブサイトを制作しました。",
    image: placeholderImages.island,
    alt: "瀬戸内海に浮かぶ中島の風景",
    href: "https://nakajima-biyori.com/",
  },
  {
    category: "PRODUCT",
    title: "週末移住レモン",
    body: "週末に島へ通いながら育てたレモンを届ける、商品ブランドとウェブサイトをつくりました。",
    image: placeholderImages.bottle,
    alt: "週末移住レモン果汁",
    href: "/product",
  },
];
---

<BaseLayout
  title="矢野、週末移住中。"
  description="平日は松山で働き、週末は中島へ。古民家を直し、レモンを育て、島に人が集まるきっかけをつくる、矢野さとしの活動を紹介します。"
>
  <section class="weekend-hero" aria-label="中島での活動マップ">
    <p class="site-name">矢野、週末移住中。</p>
    <div class="island-map" aria-label="中島での活動マップ">
      <div class="sea-waves" aria-hidden="true">
        {
          seaWaves.map((wave) => (
            <img
              class="sea-wave"
              src={seaWaveCutout.src}
              alt=""
              style={`--wave-x:${wave.x}%; --wave-y:${wave.y}%; --wave-size:${wave.size}rem; --wave-rotate:${wave.rotate}deg; --wave-opacity:${wave.opacity};`}
              loading="eager"
              decoding="async"
            />
          ))
        }
      </div>
      <img
        class="hero-ferry"
        src={nakajimaFerryCutout.src}
        alt=""
        loading="eager"
        decoding="async"
        aria-hidden="true"
      />
      <img
        class="island-map__art"
        src={islandUserCutout.src}
        alt=""
        loading="eager"
        decoding="async"
      />
      <svg class="island-map__base" viewBox="0 0 1200 760" aria-hidden="true">
        <defs>
          <filter id="roughLine">
            <feTurbulence
              type="fractalNoise"
              baseFrequency="0.017"
              numOctaves="2"
              seed="11"></feTurbulence>
            <feDisplacementMap in="SourceGraphic" scale="1.8"
            ></feDisplacementMap>
          </filter>
          <pattern
            id="paperSpeckles"
            width="42"
            height="42"
            patternUnits="userSpaceOnUse"
          >
            <circle cx="5" cy="9" r="0.9"></circle>
            <circle cx="28" cy="17" r="0.7"></circle>
            <circle cx="17" cy="34" r="0.8"></circle>
            <circle cx="38" cy="37" r="0.6"></circle>
          </pattern>
        </defs>
        <rect class="island-map__paper" width="1200" height="760"></rect>
        <path
          class="island-map__shape"
          d="M147 134C234 54 405 62 528 94c103 27 197-6 307 31 124 42 220 139 248 254 31 127-25 258-118 325-96 68-221 42-342 24-115-17-195 30-318 12-130-19-229-89-268-202-38-108 20-322 110-404Z"
        ></path>
        <path
          class="island-map__shore"
          d="M142 202c132-94 272-88 419-47 111 31 199-6 315 32 103 34 176 102 213 201"
        ></path>
        <path
          class="island-map__trail"
          d="M201 582c91-91 204-140 323-141 93 0 171 45 274 30 82-12 142-55 209-112"
        ></path>
        <path
          class="island-map__trail island-map__trail--small"
          d="M516 166c-30 88-12 155 56 209 53 43 70 92 51 147"></path>
        <g class="island-map__grass">
          <path
            d="M82 158c6-16 11-16 14 1M101 152c7-19 13-19 18-1M125 158c8-14 15-13 20 2"
          ></path>
          <path
            d="M228 96c5-13 10-13 14 0M247 91c8-15 15-15 19 1M274 94c5-11 11-11 16 1"
          ></path>
          <path
            d="M391 169c8-17 14-18 20-2M420 167c8-21 17-20 25 1M456 175c7-15 15-14 21 3"
          ></path>
          <path
            d="M690 95c7-15 14-16 19 0M719 92c8-18 17-17 24 1M752 98c6-13 13-12 18 1"
          ></path>
          <path
            d="M965 167c6-17 13-17 19 1M993 163c8-20 17-20 25 0M1030 170c7-14 14-14 20 1"
          ></path>
          <path
            d="M156 319c6-14 12-14 17 1M181 314c7-17 15-17 22 1M214 321c7-13 14-12 20 2"
          ></path>
          <path
            d="M342 349c7-16 14-16 20 0M371 345c9-19 18-19 25 1M407 354c6-12 14-12 20 2"
          ></path>
          <path
            d="M779 330c7-16 13-16 19 0M807 326c9-18 17-18 24 1M842 333c6-12 13-12 19 1"
          ></path>
          <path
            d="M1000 456c7-15 14-15 19 1M1028 452c8-19 17-18 24 1M1063 459c6-12 13-11 19 2"
          ></path>
          <path
            d="M103 520c7-15 13-15 19 1M132 515c9-19 18-18 25 1M169 523c7-12 14-11 20 2"
          ></path>
          <path
            d="M486 612c8-16 16-16 23 1M520 607c9-18 19-18 28 1M560 616c7-13 15-12 22 2"
          ></path>
          <path
            d="M753 629c6-16 13-16 19 0M782 624c9-20 18-19 25 1M819 632c7-13 14-12 20 2"
          ></path>
          <path
            d="M997 624c6-14 12-13 18 1M1022 618c8-18 16-18 23 0M1055 626c7-12 14-12 20 2"
          ></path>
          <path
            d="M270 677c6-13 12-13 18 1M296 671c8-16 16-16 23 1M329 679c6-12 13-11 19 2"
          ></path>
        </g>
        <g class="island-map__doodles">
          <path
            class="island-map__cat"
            d="M78 279l13-13 14 12 20-2 14-10 15 10M89 278c-4 19 8 31 27 29 18-2 26-13 22-30M105 289h.2M126 286h.2M64 285c-19-4-32-1-39 11"
          ></path>
          <path
            class="island-map__bird"
            d="M920 284c15-21 34-28 59-20 18 6 33 1 45-14M960 265c-1-18 7-30 25-35"
          ></path>
          <path
            class="island-map__leaf"
            d="M1096 500c-24-20-46-20-68-1 12 24 37 24 68 1Z"></path>
          <path
            class="island-map__leaf island-map__leaf--small"
            d="M184 470c-20-16-38-15-54 2 12 18 31 18 54-2Z"></path>
          <path
            class="island-map__lemon"
            d="M891 70c28-13 67-7 85 17-12 28-52 37-84 21-20-10-21-27-1-38Z"
          ></path>
          <path
            class="island-map__spark"
            d="M884 60c7-25 22-39 45-43M981 98c24 2 42 12 53 30"></path>
        </g>
        <g class="island-map__waves">
          <path d="M82 228c34-18 67 19 101 1 30-16 60 6 90 1"></path>
          <path d="M912 128c34-18 69 18 103 0 29-15 58 6 88 2"></path>
          <path d="M935 678c34-18 69 18 103 0 29-15 58 6 88 2"></path>
          <path d="M34 665c34-18 68 17 102 0 29-15 58 6 88 2"></path>
        </g>
      </svg>

      <a
        class="map-spot map-spot--yano"
        href="/about"
        aria-label="ヤノのプロフィールへ"
      >
        <span class="map-yano" aria-hidden="true">
          <img
            src={yanoWalkingCutout.src}
            alt=""
            loading="eager"
            decoding="async"
          />
        </span>
        <span>ヤノ</span>
      </a>
      <a
        class="map-spot map-spot--house"
        href="#kominka"
        aria-label="古民家再生へ"
      >
        <span class="map-house" aria-hidden="true"></span>
        <span>古民家</span>
      </a>
      <a
        class="map-spot map-spot--farm"
        href="#lemon-product"
        aria-label="レモン畑と商品へ"
      >
        <span class="map-farm" aria-hidden="true"></span>
        <span>レモン畑</span>
      </a>
    </div>
  </section>

  <section class="empathy-section content-shell reveal-section" id="about">
    <p class="section-kicker">A SMALL FIRST STEP</p>
    <div class="empathy-section__grid">
      <h2>田舎暮らし、憧れる。<br />でも踏み出せない。</h2>
      <div class="empathy-section__body">
        <p>
          いつかは自然の近くで暮らしてみたい。でも、仕事もあるし、家もあるし、いきなり移住はむずかしい。
        </p>
        <p>
          ヤノも最初はそうでした。平日は松山で働き、週末だけ船に乗って中島へ行く。暮らすほどではないけれど、ただ遊びに行くだけでもない。そんな距離感から、島との関わりが始まりました。
        </p>
      </div>
    </div>
  </section>

  <section class="concept-section reveal-section">
    <div class="concept-section__inner content-shell">
      <div>
        <p class="section-kicker">CONCEPT</p>
        <h2>週末移住という、半歩目。</h2>
      </div>
      <div class="concept-section__copy">
        <p>
          移住しなくても、島は少し味わえる。畑で採れたレモンを搾った果汁。古民家を直す日々。海掃除やマルシェ、収穫イベント。
        </p>
        <p>
          週末ごとに島で受け取ったものを、商品や発信や体験にして届けています。一歩踏み出さなくてもいい。まずは半歩、島の空気を感じてもらえたら。
        </p>
      </div>
    </div>
  </section>

  <section class="place-section content-shell reveal-section" id="nakajima">
    <div class="place-section__copy">
      <p class="section-kicker">NAKAJIMA ISLAND</p>
      <h2>中島ってどこ？</h2>
      <p>
        愛媛県松山市の沖にある、瀬戸内海の島。松山の港から船で向かうことができ、柑橘畑、海、古民家、人の暮らしが近くにあります。
      </p>
      <ul>
        <li>松山市の沖にある島</li>
        <li>船で通える、週末の距離</li>
        <li>レモンと柑橘、海と古民家のある場所</li>
      </ul>
    </div>
    <figure class="place-section__map">
      <img
        src={nakajimaMap.src}
        alt="愛媛県松山市と中島の位置を示す地図"
        loading="lazy"
      />
    </figure>
  </section>

  <section class="activities-section reveal-section" id="activities">
    <div class="content-shell">
      <header class="section-heading">
        <p class="section-kicker">WHAT YANO DOES</p>
        <h2>今、島でしていること</h2>
      </header>
      <div class="activities-section__grid">
        {
          activities.map((activity) => (
            <article id={activity.targetId}>
              <figure>
                <img src={activity.image} alt={activity.alt} loading="lazy" />
              </figure>
              <div>
                <span>{activity.number}</span>
                <h3>{activity.title}</h3>
                <p>{activity.body}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="faq-section content-shell reveal-section" id="faq">
    <header class="section-heading">
      <p class="section-kicker">QUESTIONS</p>
      <h2>気になること、先に答えます。</h2>
    </header>
    <div class="faq-section__list">
      {
        faqs.map((faq) => (
          <details>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))
      }
    </div>
  </section>

  <section class="pathways-section reveal-section" id="taste">
    <div class="content-shell">
      <header class="pathways-section__heading">
        <p class="section-kicker">NEXT ACTION</p>
        <h2>味見してみる。見に行ってみる。</h2>
        <p>
          商品を買う、活動を追う、島のことを知る。あなたの生活に近いところから、島との距離を少しだけ縮めてみてください。
        </p>
      </header>
      <div class="pathways-section__grid">
        {
          pathways.map((item) => (
            <a
              href={item.href}
              target={item.href.startsWith("http") ? "_blank" : undefined}
              rel={item.href.startsWith("http") ? "noreferrer" : undefined}
            >
              <figure>
                <img src={item.image} alt={item.alt} loading="lazy" />
              </figure>
              <p>{item.label}</p>
              <h3>{item.title}</h3>
              <span>{item.body}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="works-section content-shell reveal-section" id="works">
    <header class="section-heading">
      <p class="section-kicker">WORKS</p>
      <h2>てがけてきたこと</h2>
    </header>
    <div class="works-section__grid">
      {
        works.map((work) => (
          <a
            href={work.href}
            target={work.href.startsWith("http") ? "_blank" : undefined}
            rel={work.href.startsWith("http") ? "noreferrer" : undefined}
          >
            <figure>
              <img src={work.image} alt={work.alt} loading="lazy" />
            </figure>
            <p>{work.category}</p>
            <h3>{work.title}</h3>
            <span>{work.body}</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="recent-section reveal-section" id="recent">
    <div class="recent-section__inner content-shell">
      <div>
        <p class="section-kicker">RECENT YANO</p>
        <h2>最近のヤノはInstagramで。</h2>
      </div>
      <p>
        畑の様子、古民家の進み具合、イベントのお知らせはInstagramで更新しています。サイトでは伝えきれない、週末ごとの空気をのぞいてみてください。
      </p>
      <a href={siteConfig.social.instagram} target="_blank" rel="noreferrer"
        >Instagramを見る</a
      >
    </div>
  </section>

  <a class="back-to-map" href="#main-content" aria-label="TOPへ戻る"
    >TOPへ戻る</a
  >

  <script>

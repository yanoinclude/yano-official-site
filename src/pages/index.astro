  <script>
    document.querySelectorAll<HTMLButtonElement>(".faq-item > button").forEach((button) => {
      button.addEventListener("click", () => {
        const expanded = button.getAttribute("aria-expanded") === "true";
        button.setAttribute("aria-expanded", String(!expanded));
        button.closest(".faq-item")?.classList.toggle("is-open", !expanded);
      });
    });

    const accessMap = document.querySelector<HTMLElement>(".access-section__map");
    const accessMapFrame = accessMap?.querySelector<HTMLIFrameElement>("iframe");
    accessMapFrame?.addEventListener("load", () => accessMap?.classList.add("is-loaded"), { once: true });

    const backToTop = document.querySelector<HTMLElement>(".back-to-map");
    const updateBackToTop = () => backToTop?.classList.toggle("is-visible", window.scrollY > window.innerHeight * 0.75);
    window.addEventListener("scroll", updateBackToTop, { passive: true });
    updateBackToTop();

    const islandMap = document.querySelector<HTMLElement>("[data-yano-island]");
    const islandYano = islandMap?.querySelector<HTMLElement>("[data-island-yano]");
    const updateIslandYanoPath = () => {
      if (!islandMap || !islandYano) return;
      const { width, height } = islandMap.getBoundingClientRect();
      const point = (x: number, y: number) =>
        `${Math.round(width * x)} ${Math.round(height * y)}`;
      islandYano.style.offsetPath = `path("M ${point(0.34, 0.6)} C ${point(0.4, 0.56)} ${point(0.47, 0.55)} ${point(0.54, 0.56)} C ${point(0.6, 0.57)} ${point(0.64, 0.54)} ${point(0.68, 0.48)}")`;
    };
    if (islandMap && islandYano) {
      updateIslandYanoPath();
      new ResizeObserver(updateIslandYanoPath).observe(islandMap);
    }

    const islandReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    let islandSequenceId = 0;
    let islandMotion: Animation | undefined;
    const waitForIslandYano = (duration: number) =>
      new Promise((resolve) => window.setTimeout(resolve, duration));
    const moveIslandYano = async (
      from: string,
      to: string,
      duration: number,
      easing = "linear",
    ) => {
      if (!islandYano) return;
      islandMotion = islandYano.animate(
        [{ offsetDistance: from }, { offsetDistance: to }],
        { duration, easing, fill: "forwards" },
      );
      try {
        await islandMotion.finished;
      } catch {
        // Cancellation is expected if reduced-motion changes.
      }
    };
    const setIslandYanoState = (
      state: "walk" | "settle" | "start" | "scratch" | "idle",
    ) => {
      if (!islandYano) return;
      islandYano.classList.toggle("is-walking", state === "walk");
      islandYano.classList.toggle("is-scratching", state === "scratch");
      islandYano.classList.toggle("is-idle", state === "idle");
      islandYano.classList.toggle("is-settling", state === "settle");
      islandYano.classList.toggle("is-starting", state === "start");
    };
    const playIslandYano = async () => {
      if (!islandYano || islandReducedMotion.matches) return;
      const currentSequence = ++islandSequenceId;
      islandYano.style.offsetDistance = "0%";
      islandYano.classList.remove("is-returning");
      let forwardStart = "0%";

      while (currentSequence === islandSequenceId && !islandReducedMotion.matches) {
        setIslandYanoState("walk");
        await moveIslandYano(forwardStart, "90%", forwardStart === "0%" ? 9450 : 8820);
        if (currentSequence !== islandSequenceId || islandReducedMotion.matches) break;

        setIslandYanoState("settle");
        await moveIslandYano("90%", "100%", 1050, "cubic-bezier(0.2, 0.7, 0.2, 1)");
        if (currentSequence !== islandSequenceId || islandReducedMotion.matches) break;

        setIslandYanoState("idle");
        await waitForIslandYano(300);
        if (currentSequence !== islandSequenceId || islandReducedMotion.matches) break;

        setIslandYanoState("scratch");
        await waitForIslandYano(1200);
        if (currentSequence !== islandSequenceId || islandReducedMotion.matches) break;

        setIslandYanoState("idle");
        await waitForIslandYano(800);
        if (currentSequence !== islandSequenceId || islandReducedMotion.matches) break;

        islandYano.classList.add("is-returning");
        setIslandYanoState("start");
        await moveIslandYano("100%", "94%", 650, "cubic-bezier(0.55, 0, 0.8, 0.35)");
        if (currentSequence !== islandSequenceId || islandReducedMotion.matches) break;

        setIslandYanoState("walk");
        await moveIslandYano("94%", "10%", 8820);
        if (currentSequence !== islandSequenceId || islandReducedMotion.matches) break;

        setIslandYanoState("settle");
        await moveIslandYano("10%", "0%", 1050, "cubic-bezier(0.2, 0.7, 0.2, 1)");
        if (currentSequence !== islandSequenceId || islandReducedMotion.matches) break;

        setIslandYanoState("idle");
        await waitForIslandYano(300);
        if (currentSequence !== islandSequenceId || islandReducedMotion.matches) break;

        setIslandYanoState("scratch");
        await waitForIslandYano(1200);
        if (currentSequence !== islandSequenceId || islandReducedMotion.matches) break;

        setIslandYanoState("idle");
        await waitForIslandYano(800);
        islandYano.classList.remove("is-returning");
        setIslandYanoState("start");
        await moveIslandYano("0%", "6%", 650, "cubic-bezier(0.55, 0, 0.8, 0.35)");
        forwardStart = "6%";
      }
    };
    const handleIslandMotionPreference = () => {
      islandSequenceId += 1;
      islandMotion?.cancel();
      if (!islandYano) return;
      islandYano.style.offsetDistance = "0%";
      islandYano.classList.remove(
        "is-returning",
        "is-scratching",
        "is-idle",
        "is-settling",
        "is-starting",
      );
      islandYano.classList.add("is-walking");
      if (!islandReducedMotion.matches) void playIslandYano();
    };
    if (islandYano) {
      islandReducedMotion.addEventListener("change", handleIslandMotionPreference);
      handleIslandMotionPreference();
    }

    const revealTargets = document.querySelectorAll(".reveal-section");
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      revealTargets.forEach((target) =>
        target.setAttribute("data-in-view", "true"),
      );
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.setAttribute("data-in-view", "true");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08 },
      );
      revealTargets.forEach((target) => observer.observe(target));
    }
  </script>
</BaseLayout>


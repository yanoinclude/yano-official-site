---
import JournalCard from "@/components/sections/JournalCard.astro";
import TextLink from "@/components/ui/TextLink.astro";
import { homeContent } from "@/content/pages/home";
import { siteConfig } from "@/content/pages/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="愛媛県松山市・中島の風景とレモン"
  description={siteConfig.description}
>
  <section class="hero" aria-label="週末移住レモンのファーストビュー">
    <div class="hero__rail" aria-hidden="true">
      <span>{siteConfig.name}</span>
    </div>
    <div class="hero__track">
      <figure class="hero__image">
        <img src={homeContent.hero.image} alt={homeContent.hero.imageAlt} />
      </figure>
    </div>
    <p class="eyebrow hero__label">Nakajima, Matsuyama</p>
    <div class="hero__copy-block">
      <h1>
        <span>島の続きを、手入れする。</span>
      </h1>
    </div>
    <span class="hero__scroll" aria-hidden="true">scroll</span>
  </section>

  <section class="intro-facts-section reveal-section" id="introduction">
    <div
      class="intro-facts-section__message"
      aria-label={homeContent.intro.text}
    >
      {homeContent.intro.columns.map((column) => <p>{column}</p>)}
    </div>
    <figure class="intro-facts-section__image">
      <img src={homeContent.intro.image.src} alt={homeContent.intro.imageAlt} />
    </figure>
  </section>

  <section class="short-profile reveal-section" aria-labelledby="short-profile-title">
    <div>
      <p class="section-title__en">{homeContent.shortProfile.eyebrow}</p>
      <h2 id="short-profile-title">{homeContent.shortProfile.heading}</h2>
    </div>
    <div class="short-profile__body">
      <p>{homeContent.shortProfile.body}</p>
      <a
        class="short-profile__instagram"
        href={siteConfig.social.instagram}
        target="_blank"
        rel="noreferrer"
      >
        {homeContent.shortProfile.instagramLabel}
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </section>

  <section class="timeline-section reveal-section" id="timeline">
    <header class="timeline-section__heading">
      <p class="section-title__en">{homeContent.timeline.eyebrow}</p>
      <h2>{homeContent.timeline.heading}</h2>
      <p>{homeContent.timeline.lead}</p>
    </header>

    <div class="timeline-chapters">
      {
        homeContent.timeline.groups.map((group) => (
          <details class="timeline-chapter">
            <summary>
              <span class="timeline-chapter__number">{group.number}</span>
              <span class="timeline-chapter__title">
                <strong>{group.title}</strong>
                <small>{group.body}</small>
              </span>
              <time>{group.period}</time>
              <span class="timeline-chapter__toggle" aria-hidden="true">
                ＋
              </span>
            </summary>
            <ol>
              {group.itemIndexes.map((itemIndex) => {
                const item = homeContent.timeline.items[itemIndex];
                return (
                  <li>
                    <time>{item.date}</time>
                    <div>
                      <h3>{item.title}</h3>
                      <p>{item.body}</p>
                    </div>
                  </li>
                );
              })}
            </ol>
          </details>
        ))
      }
    </div>

    <div class="timeline-current">
      <p>{homeContent.timeline.current.date}</p>
      <div>
        <h3>{homeContent.timeline.current.heading}</h3>
        <p>{homeContent.timeline.current.body}</p>
      </div>
      <nav aria-label="現在の活動を詳しく見る">
        <TextLink href="/about" variant="quiet">矢野について</TextLink>
        <TextLink href="/kominka" variant="quiet">古民家のこと</TextLink>
        <TextLink href="/lemon-farm" variant="quiet">レモン畑のこと</TextLink>
      </nav>
    </div>
    <div class="timeline-more">
      <TextLink href="/story" variant="quiet">
        {homeContent.timeline.moreLabel}
      </TextLink>
    </div>
  </section>

  <section class="scenery-section reveal-section" id="scenery">
    <div class="scenery-place">
      <header class="scenery-place__heading">
        <h2>{homeContent.scenery.heading}</h2>
        <p>{homeContent.scenery.eyebrow}</p>
      </header>
      <div class="scenery-place__copy">
        {homeContent.scenery.body.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <figure class="scenery-place__photo">
        <img
          src={homeContent.scenery.featureImage.src}
          alt={homeContent.scenery.featureImageAlt}
        />
      </figure>
    </div>
    <div
      class="scenery-marquee"
      tabindex="0"
      role="region"
      aria-label="中島の風景写真。横方向にスクロールできます。"
    >
      <div class="scenery-marquee__track">
        <div class="scenery-marquee__set">
          {
            homeContent.scenery.slides.map((slide) => (
              <figure
                class:list={[
                  "scenery-card",
                  {
                    "scenery-card--portrait": [
                      "PORT",
                      "LEMON ORCHARD",
                      "KOMINKA",
                    ].includes(slide.label),
                  },
                ]}
              >
                <div class="scenery-card__image">
                  <img
                    src={slide.image.src}
                    width={slide.image.width}
                    height={slide.image.height}
                    alt={slide.alt}
                    loading="lazy"
                  />
                </div>
                <figcaption>
                  <p class="scenery-card__label">{slide.label}</p>
                  <h3>{slide.title}</h3>
                  <p>{slide.description}</p>
                </figcaption>
              </figure>
            ))
          }
        </div>
      </div>
    </div>
    <a class="scenery-image-link" href="/landscape">島の風景をもっと見る</a>
  </section>

  <section class="work-section reveal-section" id="activities">
    <div class="work-section__heading">
      <p class="section-title__en">{homeContent.activities.eyebrow}</p>
      <h2>{homeContent.activities.heading}</h2>
      <p class="work-section__lead">{homeContent.activities.lead}</p>
    </div>
    <div class="work-section__list">
      {
        homeContent.activities.items.map((item, index) => (
          <article class="work-story">
            <figure>
              <img src={item.image} alt={item.alt} loading="lazy" />
            </figure>
            <div class="work-story__copy">
              <p class="work-story__number">
                {String(index + 1).padStart(2, "0")}
              </p>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
              <TextLink href={item.href} variant="quiet">
                詳しく見る
              </TextLink>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="yano-section reveal-section" id="about">
    <figure class="yano-section__image">
      <img src={homeContent.about.image} alt={homeContent.about.imageAlt} />
    </figure>
    <div class="yano-section__copy">
      <p class="section-title__en">{homeContent.about.eyebrow}</p>
      <h2>{homeContent.about.heading}</h2>
      <p class="yano-section__role">週末移住レモン</p>
      <p class="yano-section__name">{homeContent.about.name}</p>
      {homeContent.about.body.map((paragraph) => <p>{paragraph}</p>)}
      <TextLink href="/about" variant="quiet">詳しいプロフィール</TextLink>
    </div>
  </section>

  <section class="people-section reveal-section" id="people">
    <div class="people-section__heading">
      <p class="section-title__en">{homeContent.people.eyebrow}</p>
      <h2>{homeContent.people.heading}</h2>
      <p>{homeContent.people.body}</p>
    </div>
    <div class="people-section__list">
      {
        homeContent.people.items.map((person) => (
          <article class="person-story">
            <figure>
              <img src={person.image} alt={person.imageAlt} loading="lazy" />
            </figure>
            <div>
              <p class="person-story__relation">{person.relation}</p>
              <h3>{person.name}</h3>
              <p>{person.body}</p>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="experience-section reveal-section" id="experience">
    <div class="section-grid section-grid--reverse">
      <figure class="section-photo section-photo--landscape">
        <img
          src={homeContent.experience.image}
          alt={homeContent.experience.imageAlt}
        />
      </figure>
      <div class="section-copy">
        <p class="eyebrow">{homeContent.experience.eyebrow}</p>
        <h2>{homeContent.experience.heading}</h2>
        <p>{homeContent.experience.body}</p>
      </div>
    </div>
    <ul class="experience-list" aria-label="島との関わり方">
      {
        homeContent.experience.items.map((item, index) => (
          <li>
            <a href={item.href}>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <strong>{item.title}</strong>
              <p>{item.body}</p>
              <span aria-hidden="true">→</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="journal-section reveal-section" id="journal">
    <div class="section-title section-title--row">
      <div>
        <p class="section-title__en">{homeContent.journal.eyebrow}</p>
        <h2>{homeContent.journal.heading}</h2>
      </div>
      <p>{homeContent.journal.body}</p>
    </div>
    <div class="journal-showcase">
      <article class="journal-feature">
        <figure>
          <img
            src={homeContent.journal.items[0].image}
            alt={homeContent.journal.items[0].imageAlt}
          />
        </figure>
        <JournalCard
          title={homeContent.journal.items[0].title}
          date={homeContent.journal.items[0].date}
          excerpt={homeContent.journal.items[0].excerpt}
          href={homeContent.journal.items[0].href}
        />
      </article>
      <div class="journal-list">
        {
          homeContent.journal.items
            .slice(1)
            .map((article) => (
              <JournalCard
                title={article.title}
                date={article.date}
                excerpt={article.excerpt}
                href={article.href}
              />
            ))
        }
      </div>
    </div>
  </section>

  <section class="product-section reveal-section" id="product">
    <figure class="product-section__image">
      <img
        src={homeContent.product.image}
        alt={homeContent.product.imageAlt}
        loading="lazy"
      />
    </figure>
    <div class="product-section__text">
      <p class="section-title__en">{homeContent.product.eyebrow}</p>
      <h2>{homeContent.product.heading}</h2>
      <p class="product-section__lead">{homeContent.product.lead}</p>
      <p>{homeContent.product.body}</p>
      <TextLink href={homeContent.product.href} variant="quiet">
        {homeContent.product.cta}
      </TextLink>
    </div>
  </section>

  <section class="news-section reveal-section" id="news">
    <div class="news-section__inner">
      <div>
        <p class="section-title__en">{homeContent.news.eyebrow}</p>
        <h2>{homeContent.news.heading}</h2>
      </div>
      <div class="news-list">
        {
          homeContent.news.items.map((item) => (
            <a href={item.href}>
              <time datetime={item.date.replaceAll(".", "-")}>{item.date}</time>
              <span>{item.title}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section
    class="closing-section reveal-section"
    aria-label="クロージングメッセージ"
  >
    <figure>
      <img src={homeContent.closing.image} alt={homeContent.closing.imageAlt} />
    </figure>
    <div>
      <div class="closing-section__body">
        <p>この島に、帰ってこられる風景を。</p>
      </div>
    </div>
  </section>

  <script>
    const revealTargets = document.querySelectorAll(".reveal-section");

    if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.setAttribute("data-in-view", "true");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 },
      );

      revealTargets.forEach((target) => observer.observe(target));
    } else {
      revealTargets.forEach((target) =>
        target.setAttribute("data-in-view", "true"),
      );
    }
  </script>
</BaseLayout>

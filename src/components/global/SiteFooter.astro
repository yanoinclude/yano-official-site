---
import { siteConfig } from "@/content/pages/site";

const navigationGroups = [
  {
    title: "サイトを見る",
    items: [
      { label: "週末移住について", href: "/#about" },
      { label: "島でしていること", href: "/#activities" },
      { label: "ヤノについて", href: "/#profile" },
      { label: "中島へのアクセス", href: "/#nakajima" },
      { label: "島との関わり方", href: "/#taste" },
      { label: "記録", href: "/columns" },
    ],
  },
  {
    title: "ヤノとつながる",
    items: [
      { label: "お問い合わせ", href: "/contact" },
      {
        label: "Instagram",
        href: siteConfig.social.instagram,
        external: true,
      },
      { label: "note", href: siteConfig.social.note, external: true },
    ],
  },
] as const;
---

<footer class="site-footer" id="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <p class="site-footer__copy">{siteConfig.mainCopy}</p>
      <p>平日は働き、週末は船で中島へ。</p>
      <a class="site-footer__product" href="/product">
        <span>週末移住レモンを見る</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="site-footer__navigation">
      {
        navigationGroups.map((group) => (
          <nav aria-label={group.title}>
            <p>{group.title}</p>
            <ul>
              {group.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class:list={{
                      "site-footer__accent": "accent" in item && item.accent,
                    }}
                    target={
                      "external" in item && item.external ? "_blank" : undefined
                    }
                    rel={
                      "external" in item && item.external
                        ? "noopener noreferrer"
                        : undefined
                    }
                  >
                    {item.label}
                    {"external" in item && item.external && (
                      <span aria-hidden="true">↗</span>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <div class="site-footer__bottom">
      <a href={`mailto:${siteConfig.contact.email}`}>
        {siteConfig.contact.email}
      </a>
      <div>
        <a href="/privacy">プライバシーポリシー</a>
        <small>&copy; {new Date().getFullYear()} 週末移住レモン</small>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer__inner {
    display: grid;
    grid-template-columns: minmax(17rem, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(4rem, 8vw, 8rem);
    width: min(calc(100% - 8rem), 1180px);
    padding-block: clamp(5rem, 8vw, 7rem) 2.5rem;
  }
  .site-footer__brand > p:not(.site-footer__copy) {
    margin-top: 0.35rem;
  }
  .site-footer__product {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: min(100%, 21rem);
    margin-top: 2.5rem;
    padding: 1.1rem 1.25rem;
    border-radius: 0.5rem 1.75rem 0.5rem 0.5rem;
    background: var(--island-lemon);
    color: #2e4568;
  }
  .site-footer__navigation {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1.5rem, 3vw, 3rem);
  }
  .site-footer__navigation nav > p {
    margin-bottom: 1.25rem;
    color: #50627a;
    font-size: 0.68rem;
    letter-spacing: 0.15em;
  }
  .site-footer__navigation nav ul {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.8rem;
  }
  .site-footer__navigation a {
    display: inline-flex;
    gap: 0.35rem;
    align-items: center;
    line-height: 1.6;
  }
  .site-footer__bottom {
    grid-column: 1 / -1;
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgb(46 69 104 / 16%);
  }
  .site-footer__bottom > div {
    display: flex;
    gap: 2rem;
    align-items: center;
  }
  .site-footer__bottom > div a,
  .site-footer__bottom small {
    color: #50627a;
    font-size: 0.7rem;
  }
  @media (max-width: 900px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
      gap: 3.5rem;
      width: calc(100% - 4rem);
    }
  }
  @media (max-width: 640px) {
    .site-footer__inner {
      width: calc(100% - 40px);
      gap: 3rem;
      padding-block: 4rem 2rem;
    }
    .site-footer__copy {
      font-size: 1.35rem;
      line-height: 1.45;
    }
    .site-footer__brand > p:not(.site-footer__copy) {
      margin-top: 0.6rem;
      font-size: 0.9375rem;
      line-height: 1.7;
    }
    .site-footer__product {
      width: 100%;
      min-height: 50px;
      margin-top: 1.75rem;
      font-size: 0.9375rem;
    }
    .site-footer__navigation {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem 1.5rem;
    }
    .site-footer__navigation nav ul { gap: 0.25rem; }
    .site-footer__navigation a {
      min-height: 44px;
      font-size: 0.9rem;
      line-height: 1.5;
    }
    .site-footer__bottom {
      display: grid;
      gap: 0.75rem;
    }
    .site-footer__bottom > a { min-height: 44px; font-size: 0.875rem; }
    .site-footer__bottom > div {
      justify-content: space-between;
      gap: 1rem;
    }
    .site-footer__bottom > div a,
    .site-footer__bottom small { font-size: 0.78rem; line-height: 1.6; }
  }
  @media (max-width: 420px) {
    .site-footer__inner {
      gap: 3rem;
      padding-top: 3.5rem;
    }
    .site-footer__product {
      width: 100%;
      min-height: 4rem;
      margin-top: 2rem;
      padding-inline: 1.25rem;
    }
    .site-footer__navigation {
      gap: 2rem 1rem;
    }
    .site-footer__navigation nav > p {
      margin-bottom: 1rem;
    }
    .site-footer__navigation nav ul {
      gap: 0.7rem;
    }
    .site-footer__navigation a {
      font-size: 0.9rem;
    }
    .site-footer__bottom > div {
      display: grid;
    }
  }

  .site-footer {
    background: #172b4b !important;
    color: #fff;
  }
  .site-footer__copy,
  .site-footer__brand > p,
  .site-footer__navigation a,
  .site-footer__bottom > a {
    color: #fff;
  }
  .site-footer__navigation nav > p,
  .site-footer__bottom > div a,
  .site-footer__bottom small {
    color: rgb(255 255 255 / 74%);
  }
  .site-footer__product {
    border: 2px solid #f8dc42;
    background: #f8dc42;
    color: #172b4b;
    font-weight: 800;
  }
  .site-footer__product:focus-visible,
  .site-footer__navigation a:focus-visible,
  .site-footer__bottom a:focus-visible {
    outline: 3px solid #f8dc42;
    outline-offset: 4px;
  }
  .site-footer__bottom { border-top-color: rgb(255 255 255 / 24%); }

  /* Branded navy footer */
  .site-footer {
    width: 100%;
    border-top: 3px solid #f8dc42;
    background: #102a4d !important;
    color: #fffdf5;
  }
  .site-footer__inner {
    display: grid;
    grid-template-columns: minmax(18rem, 0.85fr) minmax(31rem, 1.15fr);
    gap: clamp(3rem, 7vw, 6rem);
    width: min(calc(100% - 8rem), 1180px);
    margin-inline: auto;
    padding-block: clamp(4rem, 6vw, 5rem) 2rem;
  }
  .site-footer__copy {
    margin: 0;
    color: #fffdf5;
    font-size: clamp(1.65rem, 2.4vw, 2rem);
    font-weight: 800;
    line-height: 1.4;
  }
  .site-footer__brand > p:not(.site-footer__copy) {
    margin: 0.8rem 0 0;
    color: rgb(255 253 245 / 84%);
    font-size: 1rem;
    line-height: 1.8;
  }
  .site-footer__product {
    display: inline-flex;
    justify-content: space-between;
    align-items: center;
    width: fit-content;
    min-width: 18rem;
    min-height: 3.5rem;
    margin-top: 1.75rem;
    padding: 0.8rem 1.5rem;
    border: 2px solid #f8dc42;
    border-radius: 0.75rem;
    background: #f8dc42;
    color: #102a4d;
    font-size: 0.95rem;
    font-weight: 800;
    text-decoration: none;
    transition: transform 180ms ease, box-shadow 180ms ease, background-color 180ms ease;
  }
  .site-footer__product:hover,
  .site-footer__product:focus-visible {
    background: #ffe865;
    box-shadow: 0 0.3rem 0 rgb(0 0 0 / 24%);
    transform: translateY(-2px);
  }
  .site-footer__navigation {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(2rem, 5vw, 4rem);
  }
  .site-footer__navigation nav > p {
    margin: 0 0 1.25rem;
    color: #f8dc42;
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0.08em;
  }
  .site-footer__navigation nav ul {
    display: grid;
    gap: 0.85rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .site-footer__navigation a,
  .site-footer__bottom a {
    color: #fffdf5;
    text-decoration: none;
  }
  .site-footer__navigation a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    width: fit-content;
    font-size: 0.98rem;
    line-height: 1.65;
    transition: color 180ms ease, transform 180ms ease;
  }
  .site-footer__navigation a:hover,
  .site-footer__navigation a:focus-visible,
  .site-footer__bottom a:hover,
  .site-footer__bottom a:focus-visible {
    color: #f8dc42;
  }
  .site-footer__navigation a:hover,
  .site-footer__navigation a:focus-visible { transform: translateX(3px); }
  .site-footer__product:focus-visible,
  .site-footer__navigation a:focus-visible,
  .site-footer__bottom a:focus-visible {
    outline: 3px solid #f8dc42;
    outline-offset: 4px;
  }
  .site-footer__bottom {
    grid-column: 1 / -1;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    margin-top: 0;
    padding-top: 1.75rem;
    border-top: 1px solid rgb(255 255 255 / 28%);
  }
  .site-footer__bottom > a,
  .site-footer__bottom > div a,
  .site-footer__bottom small {
    color: rgb(255 253 245 / 82%);
    font-size: 0.78rem;
    line-height: 1.6;
  }
  .site-footer__bottom > div { display: flex; align-items: center; gap: 2rem; }

  @media (max-width: 900px) and (min-width: 768px) {
    .site-footer__inner { grid-template-columns: minmax(15rem, 0.8fr) minmax(27rem, 1.2fr); width: calc(100% - 4rem); gap: 2.5rem; }
    .site-footer__product { min-width: 0; width: 100%; }
  }

  @media (max-width: 767px) {
    .site-footer__inner {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2.25rem;
      width: calc(100% - 32px);
      padding-block: 3rem 1.5rem;
    }
    .site-footer__copy { font-size: clamp(1.25rem, 5.8vw, 1.375rem); }
    .site-footer__brand > p:not(.site-footer__copy) { font-size: 0.9375rem; }
    .site-footer__product { width: 100%; min-width: 0; min-height: 50px; margin-top: 1.25rem; }
    .site-footer__navigation { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
    .site-footer__navigation nav > p { margin-bottom: 0.65rem; font-size: 0.8125rem; }
    .site-footer__navigation nav ul { gap: 0; }
    .site-footer__navigation a { width: 100%; min-height: 44px; font-size: 0.875rem; line-height: 1.5; }
    .site-footer__bottom { display: grid; justify-content: stretch; gap: 0.45rem; padding-top: 1.25rem; }
    .site-footer__bottom > a { min-height: 32px; display: flex; align-items: center; font-size: 0.78rem; }
    .site-footer__bottom > div { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 0.35rem 1rem; }
    .site-footer__bottom > div a { min-height: 32px; display: flex; align-items: center; }
    .site-footer__bottom small { display: flex; align-items: center; min-height: 32px; }
  }

  @media (max-width: 374px) {
    .site-footer__inner { width: calc(100% - 24px); }
    .site-footer__navigation { gap: 0.75rem; }
    .site-footer__navigation a { font-size: 0.8125rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-footer a { transition: none; }
  }
</style>

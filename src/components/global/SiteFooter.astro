---
import { siteConfig } from "@/content/pages/site";

const navigationGroups = [
  {
    title: "サイトを見る",
    items: [
      { label: "ヤノについて", href: "/about" },
      { label: "できること", href: "/#services" },
      { label: "手入れしてきたもの", href: "/#works" },
      { label: "記録", href: "/columns" },
    ],
  },
  {
    title: "ヤノと関わる",
    items: [
      { label: "商品を見る", href: "/product", accent: true },
      { label: "島との関わり方", href: "/visit" },
      { label: "お問い合わせ", href: "/contact" },
      { label: "古民家", href: "/kominka" },
      { label: "レモン農園", href: "/lemon-farm" },
    ],
  },
  {
    title: "外部・規約",
    items: [
      {
        label: "Instagram",
        href: siteConfig.social.instagram,
        external: true,
      },
      { label: "note", href: siteConfig.social.note, external: true },
      { label: "プライバシーポリシー", href: "/privacy" },
    ],
  },
] as const;
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <p class="site-footer__copy">{siteConfig.mainCopy}</p>
      <p>{siteConfig.activityCopy}</p>
      <a class="site-footer__product" href="/product">
        <span>週末移住レモン果汁を見る</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="site-footer__navigation">
      {
        navigationGroups.map((group) => (
          <nav aria-label={group.title}>
            <p>{group.title}</p>
            <ul>
              {group.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class:list={{
                      "site-footer__accent": "accent" in item && item.accent,
                    }}
                    target={
                      "external" in item && item.external ? "_blank" : undefined
                    }
                    rel={
                      "external" in item && item.external
                        ? "noreferrer"
                        : undefined
                    }
                  >
                    {item.label}
                    {"external" in item && item.external && (
                      <span aria-hidden="true">↗</span>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <div class="site-footer__bottom">
      <a href={`mailto:${siteConfig.contact.email}`}>
        {siteConfig.contact.email}
      </a>
      <small>&copy; {new Date().getFullYear()} {siteConfig.name}</small>
    </div>
  </div>
</footer>

<style>
  .site-footer__inner {
    display: grid;
    grid-template-columns: minmax(17rem, 0.75fr) minmax(0, 1.25fr);
    gap: clamp(4rem, 8vw, 8rem);
    width: min(calc(100% - 8rem), 1180px);
    padding-block: clamp(5rem, 8vw, 7rem) 2.5rem;
  }
  .site-footer__brand > p:not(.site-footer__copy) {
    margin-top: 0.35rem;
  }
  .site-footer__product {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: min(100%, 21rem);
    margin-top: 2.5rem;
    padding: 1.1rem 1.25rem;
    border-radius: 0.5rem 1.75rem 0.5rem 0.5rem;
    background: #f1e89f;
    color: #26362a;
  }
  .site-footer__navigation {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1.5rem, 3vw, 3rem);
  }
  .site-footer__navigation nav > p {
    margin-bottom: 1.25rem;
    color: #687451;
    font-size: 0.68rem;
    letter-spacing: 0.15em;
  }
  .site-footer__navigation nav ul {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.8rem;
  }
  .site-footer__navigation a {
    display: inline-flex;
    gap: 0.35rem;
    align-items: center;
    line-height: 1.6;
  }
  .site-footer__accent {
    padding-bottom: 0.15rem;
    border-bottom: 1px solid #d2c458;
  }
  .site-footer__bottom {
    grid-column: 1 / -1;
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(38, 54, 42, 0.16);
  }
  @media (max-width: 900px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
      gap: 3.5rem;
      width: calc(100% - 4rem);
    }
  }
  @media (max-width: 640px) {
    .site-footer__inner {
      width: calc(100% - 2rem);
      padding-block: 4rem 2rem;
    }
    .site-footer__navigation {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem 1.5rem;
    }
    .site-footer__navigation nav:first-child {
      grid-column: 1 / -1;
    }
    .site-footer__bottom {
      display: grid;
      gap: 0.75rem;
    }
  }
</style>

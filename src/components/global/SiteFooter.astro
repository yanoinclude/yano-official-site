---
import { siteConfig } from "@/content/pages/site";

const navigationGroups = [
  {
    title: "サイトを見る",
    items: [
      { label: "ヤノについて", href: "/about" },
      { label: "できること", href: "/#services" },
      { label: "手入れしてきたもの", href: "/#works" },
      { label: "記録", href: "/columns" },
    ],
  },
  {
    title: "ヤノとつながる",
    items: [
      { label: "お問い合わせ", href: "/contact" },
      {
        label: "Instagram",
        href: siteConfig.social.instagram,
        external: true,
      },
      { label: "note", href: siteConfig.social.note, external: true },
    ],
  },
] as const;
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <p class="site-footer__copy">{siteConfig.mainCopy}</p>
      <p>{siteConfig.activityCopy}</p>
      <a class="site-footer__product" href="/product">
        <span>レモン果汁を見る</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="site-footer__navigation">
      {
        navigationGroups.map((group) => (
          <nav aria-label={group.title}>
            <p>{group.title}</p>
            <ul>
              {group.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class:list={{
                      "site-footer__accent": "accent" in item && item.accent,
                    }}
                    target={
                      "external" in item && item.external ? "_blank" : undefined
                    }
                    rel={
                      "external" in item && item.external
                        ? "noreferrer"
                        : undefined
                    }
                  >
                    {item.label}
                    {"external" in item && item.external && (
                      <span aria-hidden="true">↗</span>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <div class="site-footer__bottom">
      <a href={`mailto:${siteConfig.contact.email}`}>
        {siteConfig.contact.email}
      </a>
      <div>
        <a href="/privacy">プライバシーポリシー</a>
        <small>&copy; {new Date().getFullYear()} {siteConfig.name}</small>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer__inner {
    display: grid;
    grid-template-columns: minmax(17rem, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(4rem, 8vw, 8rem);
    width: min(calc(100% - 8rem), 1180px);
    padding-block: clamp(5rem, 8vw, 7rem) 2.5rem;
  }
  .site-footer__brand > p:not(.site-footer__copy) {
    margin-top: 0.35rem;
  }
  .site-footer__product {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: min(100%, 21rem);
    margin-top: 2.5rem;
    padding: 1.1rem 1.25rem;
    border-radius: 0.5rem 1.75rem 0.5rem 0.5rem;
    background: var(--island-lemon);
    color: #26362a;
  }
  .site-footer__navigation {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1.5rem, 3vw, 3rem);
  }
  .site-footer__navigation nav > p {
    margin-bottom: 1.25rem;
    color: #687451;
    font-size: 0.68rem;
    letter-spacing: 0.15em;
  }
  .site-footer__navigation nav ul {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.8rem;
  }
  .site-footer__navigation a {
    display: inline-flex;
    gap: 0.35rem;
    align-items: center;
    line-height: 1.6;
  }
  .site-footer__bottom {
    grid-column: 1 / -1;
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(38, 54, 42, 0.16);
  }
  .site-footer__bottom > div {
    display: flex;
    gap: 2rem;
    align-items: center;
  }
  .site-footer__bottom > div a,
  .site-footer__bottom small {
    color: #74786f;
    font-size: 0.7rem;
  }
  @media (max-width: 900px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
      gap: 3.5rem;
      width: calc(100% - 4rem);
    }
  }
  @media (max-width: 640px) {
    .site-footer__inner {
      width: calc(100% - 2rem);
      padding-block: 4rem 2rem;
    }
    .site-footer__navigation {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem 1.5rem;
    }
    .site-footer__bottom {
      display: grid;
      gap: 0.75rem;
    }
    .site-footer__bottom > div {
      justify-content: space-between;
      gap: 1rem;
    }
  }
  @media (max-width: 420px) {
    .site-footer__inner {
      gap: 3rem;
      padding-top: 3.5rem;
    }
    .site-footer__copy {
      font-size: 1.35rem;
    }
    .site-footer__product {
      width: 100%;
      min-height: 4rem;
      margin-top: 2rem;
      padding-inline: 1.25rem;
    }
    .site-footer__navigation {
      gap: 2rem 1rem;
    }
    .site-footer__navigation nav > p {
      margin-bottom: 1rem;
    }
    .site-footer__navigation nav ul {
      gap: 0.7rem;
    }
    .site-footer__navigation a {
      font-size: 0.8rem;
    }
    .site-footer__bottom > div {
      display: grid;
    }
  }
</style>

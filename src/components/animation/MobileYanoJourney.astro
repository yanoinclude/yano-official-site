<div class="yano-journey" aria-hidden="true" data-yano-journey>
  <div class="yano-journey__traveler is-walking" data-yano-traveler>
    <span class="yano-sprite yano-sprite--walk">
      <img
        src="/images/animation/yano-walk-sprite-15frames.png"
        alt=""
        width="3900"
        height="264"
        loading="eager"
        decoding="async"
      />
    </span>
    <span class="yano-sprite yano-sprite--scratch">
      <img
        src="/images/animation/yano-scratch-sprite-6frames.png"
        alt=""
        width="1560"
        height="264"
        loading="eager"
        decoding="async"
      />
    </span>
  </div>
</div>

<script>
  const journey = document.querySelector<HTMLElement>("[data-yano-journey]");
  const traveler = journey?.querySelector<HTMLElement>("[data-yano-traveler]");
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  let sequenceId = 0;
  let activeAnimation: Animation | undefined;

  const wait = (duration: number) =>
    new Promise((resolve) => window.setTimeout(resolve, duration));

  const move = async (from: string, to: string, duration: number) => {
    if (!traveler) return;
    activeAnimation = traveler.animate(
      [{ offsetDistance: from }, { offsetDistance: to }],
      { duration, easing: "linear", fill: "forwards" },
    );
    try {
      await activeAnimation.finished;
    } catch {
      // Animation cancellation is expected when reduced-motion changes.
    }
  };

  const setPath = () => {
    if (!journey || !traveler) return;
    const pathEnd = Math.ceil(journey.getBoundingClientRect().width + 90);
    traveler.style.offsetPath = `path("M -90 153 L ${pathEnd} 153")`;
  };

  const playSequence = async () => {
    if (!journey || !traveler || reducedMotion.matches) return;
    const currentSequence = ++sequenceId;

    while (currentSequence === sequenceId && !reducedMotion.matches) {
      setPath();
      traveler.style.visibility = "hidden";
      traveler.style.offsetDistance = "0%";
      traveler.classList.remove("is-scratching");
      traveler.classList.add("is-walking");
      await wait(1400);
      if (currentSequence !== sequenceId || reducedMotion.matches) break;

      traveler.style.visibility = "visible";
      await move("0%", "50%", 2000);
      if (currentSequence !== sequenceId || reducedMotion.matches) break;

      traveler.classList.remove("is-walking");
      traveler.classList.add("is-scratching");
      await wait(2200);
      if (currentSequence !== sequenceId || reducedMotion.matches) break;

      traveler.classList.remove("is-scratching");
      traveler.classList.add("is-walking");
      await move("50%", "100%", 1800);
    }
  };

  const handleMotionPreference = () => {
    sequenceId += 1;
    activeAnimation?.cancel();
    if (traveler) traveler.style.visibility = "hidden";
    if (!reducedMotion.matches) void playSequence();
  };

  if (journey && traveler) {
    setPath();
    window.addEventListener("resize", setPath, { passive: true });
    reducedMotion.addEventListener("change", handleMotionPreference);
    handleMotionPreference();
  }
</script>

<style>
  .yano-journey {
    position: absolute;
    z-index: 7;
    right: 0;
    bottom: 0;
    left: 0;
    display: block;
    width: 100%;
    height: 164px;
    overflow: hidden;
    overflow: clip;
    pointer-events: none;
    contain: layout paint;
  }

  @media (max-width: 767px) {
    .yano-journey {
      position: relative;
      z-index: auto;
      right: auto;
      bottom: auto;
      left: auto;
      width: 100%;
      height: 164px;
      margin-top: 1.25rem;
    }
  }

  .yano-journey__traveler {
    position: absolute;
    top: 0;
    left: 0;
    width: 120px;
    height: 150px;
    offset-path: path("M -90 153 L 1530 153");
    offset-distance: 0%;
    offset-rotate: 0deg;
    offset-anchor: 50% 100%;
    will-change: offset-distance;
  }

  .yano-sprite {
    position: absolute;
    bottom: 0;
    left: 50%;
    display: block;
    width: 137.879px;
    height: 140px;
    overflow: hidden;
    transform: translateX(-50%);
  }

  .yano-sprite img {
    display: block;
    width: auto;
    max-width: none;
    height: 140px;
    transform: translate3d(0, 0, 0);
  }

  .yano-sprite--walk { opacity: 0; }

  .yano-sprite--walk img {
    animation: yano-walk-frames 1.15s steps(15) infinite;
  }

  .yano-sprite--scratch { opacity: 0; }

  .yano-sprite--scratch img {
    animation: yano-scratch-frames 1.2s steps(6) infinite;
  }

  .is-walking .yano-sprite--walk,
  .is-scratching .yano-sprite--scratch {
    opacity: 1;
  }

  @keyframes yano-walk-frames {
    to {
      transform: translate3d(-100%, 0, 0);
    }
  }

  @keyframes yano-scratch-frames {
    to {
      transform: translate3d(-100%, 0, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .yano-journey {
      display: none;
    }

    .yano-sprite img {
      animation: none;
    }
  }
</style>

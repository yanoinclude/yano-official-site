<div
  class="yano-journey"
  aria-hidden="true"
  data-yano-journey
  data-yano-raf
  data-motion-kind="lane"
  data-start-position="4"
>
  <div class="yano-journey__traveler" data-yano-traveler>
    <span class="yano-sprite" data-yano-sprite>
      <img
        src="/images/animation/yano-30frames-v4.png"
        alt=""
        width="4800"
        height="264"
        loading="eager"
        decoding="async"
        data-yano-sheet
      />
    </span>
  </div>
</div>

<script>
  import { initYanoMotions } from "@/scripts/yanoMotion";

  const journey = document.querySelector<HTMLElement>("[data-yano-journey]");
  const traveler = journey?.querySelector<HTMLElement>("[data-yano-traveler]");

  const setPath = () => {
    if (!journey || !traveler) return;
    const pathEnd = Math.ceil(journey.getBoundingClientRect().width + 90);
    const pathY = Math.max(96, Math.round(journey.getBoundingClientRect().height - 2));
    traveler.style.offsetPath = `path("M -90 ${pathY} L ${pathEnd} ${pathY}")`;
    journey.dataset.pathPixels = String(pathEnd + 90);
  };

  setPath();
  window.addEventListener("resize", setPath, { passive: true });
  initYanoMotions();
</script>

<style>
  .yano-journey {
    position: absolute;
    z-index: 7;
    right: 0;
    bottom: 0;
    left: 0;
    display: block;
    width: 100%;
    height: 164px;
    overflow: hidden;
    overflow: clip;
    pointer-events: none;
    contain: layout paint;
  }

  @media (max-width: 767px) {
    .yano-journey {
      position: relative;
      z-index: auto;
      right: auto;
      bottom: auto;
      left: auto;
      display: block;
      width: 100%;
      height: 118px;
      margin-top: 0.5rem;
    }

  }

  .yano-journey__traveler {
    position: absolute;
    top: 0;
    left: 0;
    width: 120px;
    height: 150px;
    offset-path: path("M -90 153 L 1530 153");
    offset-distance: 0%;
    offset-rotate: 0deg;
    offset-anchor: 50% 100%;
    will-change: offset-distance;
  }

  .yano-sprite {
    position: absolute;
    bottom: 0;
    left: 50%;
    display: block;
    width: 84.848px;
    height: 140px;
    overflow: hidden;
    transform: translateX(-50%) scaleX(var(--yano-facing, 1)) translateY(var(--yano-bob, 0));
    transform-origin: 50% 100%;
    will-change: transform;
  }

  .yano-sprite img {
    display: block;
    width: auto;
    max-width: none;
    height: 140px;
    transform: translate3d(0, 0, 0);
    will-change: transform;
  }

  @media (max-width: 767px) {
    .yano-journey__traveler {
      width: 90px;
      height: 110px;
    }

    .yano-sprite {
      width: 60.606px;
      height: 100px;
    }

    .yano-sprite img { height: 100px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .yano-journey {
      display: none;
    }

    .yano-sprite img {
      animation: none;
    }
  }
</style>
